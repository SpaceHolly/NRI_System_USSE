<UserControl x:Class="Nri.PlayerClient.Views.Controls.ClassHexDirectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             MinWidth="360"
             MinHeight="280">
    <Grid>
        <Viewbox Stretch="Uniform">
            <Grid Width="420" Height="320">
                <Canvas Width="420" Height="320">
                    <Polygon Points="210,54 298,105 298,206 210,257 122,206 122,105"
                             Fill="#FF223452"
                             Stroke="#FF4EA3FF"
                             StrokeThickness="3"/>

                    <Line X1="210" Y1="54" X2="210" Y2="24" Stroke="#6A89B8" StrokeThickness="2"/>
                    <Line X1="298" Y1="105" X2="324" Y2="89" Stroke="#6A89B8" StrokeThickness="2"/>
                    <Line X1="298" Y1="206" X2="324" Y2="222" Stroke="#6A89B8" StrokeThickness="2"/>
                    <Line X1="210" Y1="257" X2="210" Y2="287" Stroke="#6A89B8" StrokeThickness="2"/>
                    <Line X1="122" Y1="206" X2="96" Y2="222" Stroke="#6A89B8" StrokeThickness="2"/>
                    <Line X1="122" Y1="105" X2="96" Y2="89" Stroke="#6A89B8" StrokeThickness="2"/>

                    <Border Canvas.Left="130" Canvas.Top="108" Width="160" Height="96" Background="Transparent">
                        <TextBlock Text="Новичок"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </Border>

                    <TextBlock Text="Защитник"
                               Width="110"
                               TextAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Canvas.Left="155"
                               Canvas.Top="63"/>
                    <TextBlock Text="Передовой"
                               Width="92"
                               TextAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               RenderTransformOrigin="0.5,0.5"
                               Canvas.Left="262"
                               Canvas.Top="102">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="60"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Text="Рейнджер"
                               Width="92"
                               TextAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               RenderTransformOrigin="0.5,0.5"
                               Canvas.Left="262"
                               Canvas.Top="182">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="-60"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Text="Самурай"
                               Width="110"
                               TextAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Canvas.Left="155"
                               Canvas.Top="224"/>
                    <TextBlock Text="Маг"
                               Width="84"
                               TextAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               RenderTransformOrigin="0.5,0.5"
                               Canvas.Left="74"
                               Canvas.Top="184">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="60"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Text="Изобретатель"
                               Width="112"
                               TextAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               RenderTransformOrigin="0.5,0.5"
                               Canvas.Left="54"
                               Canvas.Top="100">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="-60"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Canvas>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>
