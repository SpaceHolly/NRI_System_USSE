<UserControl x:Class="Nri.PlayerClient.Views.Controls.ClassHexDirectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             MinWidth="360"
             MinHeight="280">
    <Grid>
        <Viewbox Stretch="Uniform">
            <Grid Width="420" Height="320">
                <Canvas Width="420" Height="320">
                    <Polygon Points="210,54 298,105 298,206 210,257 122,206 122,105"
                             Fill="#FF223452"
                             Stroke="#FF4EA3FF"
                             StrokeThickness="3"/>

                    <Line X1="210" Y1="54" X2="210" Y2="24" Stroke="#6A89B8" StrokeThickness="2"/>
                    <Line X1="298" Y1="105" X2="324" Y2="89" Stroke="#6A89B8" StrokeThickness="2"/>
                    <Line X1="298" Y1="206" X2="324" Y2="222" Stroke="#6A89B8" StrokeThickness="2"/>
                    <Line X1="210" Y1="257" X2="210" Y2="287" Stroke="#6A89B8" StrokeThickness="2"/>
                    <Line X1="122" Y1="206" X2="96" Y2="222" Stroke="#6A89B8" StrokeThickness="2"/>
                    <Line X1="122" Y1="105" X2="96" Y2="89" Stroke="#6A89B8" StrokeThickness="2"/>

                    <Border Canvas.Left="130" Canvas.Top="108" Width="160" Height="96" Background="Transparent">
                        <TextBlock Text="Новичок"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </Border>

                    <Border Canvas.Left="154" Canvas.Top="57" Width="112" Height="24" Background="#FF1E2A40" BorderBrush="#6A89B8" BorderThickness="1" CornerRadius="12">
                        <Button Command="{Binding DirectionSelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="defender"
                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Content="Защитник"/>
                    </Border>
                    <Border Canvas.Left="281" Canvas.Top="106" Width="100" Height="24" Background="#FF1E2A40" BorderBrush="#6A89B8" BorderThickness="1" CornerRadius="12">
                        <Button Command="{Binding DirectionSelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="vanguard"
                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Content="Передовой"/>
                    </Border>
                    <Border Canvas.Left="281" Canvas.Top="184" Width="100" Height="24" Background="#FF1E2A40" BorderBrush="#6A89B8" BorderThickness="1" CornerRadius="12">
                        <Button Command="{Binding DirectionSelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="ranger"
                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Content="Рейнджер"/>
                    </Border>
                    <Border Canvas.Left="154" Canvas.Top="229" Width="112" Height="24" Background="#FF1E2A40" BorderBrush="#6A89B8" BorderThickness="1" CornerRadius="12">
                        <Button Command="{Binding DirectionSelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="samurai"
                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Content="Самурай"/>
                    </Border>
                    <Border Canvas.Left="39" Canvas.Top="184" Width="88" Height="24" Background="#FF1E2A40" BorderBrush="#6A89B8" BorderThickness="1" CornerRadius="12">
                        <Button Command="{Binding DirectionSelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="mage"
                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Content="Маг"/>
                    </Border>
                    <Border Canvas.Left="28" Canvas.Top="106" Width="114" Height="24" Background="#FF1E2A40" BorderBrush="#6A89B8" BorderThickness="1" CornerRadius="12">
                        <Button Command="{Binding DirectionSelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="inventor"
                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Content="Изобретатель"/>
                    </Border>
                </Canvas>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>
