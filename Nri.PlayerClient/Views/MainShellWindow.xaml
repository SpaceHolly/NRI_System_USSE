                                                <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="Все навыки" FontWeight="Bold" FontSize="16"/>
                                                            <TextBlock Text="Справочник рассчитан на большое количество записей и отдельную карточку детали." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                            <ListBox x:Name="SkillCatalogList" ItemsSource="{Binding SkillCatalogRows}"/>
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Border>
                                                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="8,0,0,0">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <StackPanel>
                                                            <TextBlock Text="Карточка навыка" FontWeight="Bold" FontSize="16"/>
                                                            <TextBlock Text="{Binding ElementName=SkillCatalogList, Path=SelectedItem, TargetNullValue=Навык не выбран}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                                            <TextBlock Text="Тип" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                                                            <TextBlock Text="Пассивный / активный / особый placeholder"/>
                                                            <TextBlock Text="Описание" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                                                            <TextBlock Text="Здесь будут полный эффект, описание, требования и взаимодействие с классами." TextWrapping="Wrap"/>
                                                            <TextBlock Text="Доступность" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                                                            <TextBlock Text="Причина недоступности или условия получения будут показаны здесь." TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Grid>
                                        </TabItem>
                                        <TabItem Header="Навыки персонажа/компаньона">
                                            <Grid Margin="4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Width="220" Text="{Binding SelectedSkillId, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <Button Content="Получить навык" Command="{Binding AcquireSkillCommand}"/>
                                                </StackPanel>
                                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.1*"/>
                                                        <ColumnDefinition Width="1.4*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="Список навыков персонажа" FontWeight="Bold" FontSize="16"/>
                                                                <TextBlock Text="Навыки остаются доступными даже при маленькой высоте окна за счёт скролла." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                                <ListBox x:Name="CharacterSkillsList" ItemsSource="{Binding SkillRows}"/>
                                                            </ScrollViewer>
                                                        </Grid>
                                                    </Border>
                                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="8,0,0,0">
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                            <StackPanel>
                                                                <TextBlock Text="Карточка выбранного навыка" FontWeight="Bold" FontSize="16"/>
                                                                <TextBlock Text="{Binding ElementName=CharacterSkillsList, Path=SelectedItem, TargetNullValue=Навык не выбран}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                                                <TextBlock Text="Тип" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                                                                <TextBlock Text="Боевой / социальный / ремесленный placeholder"/>
                                                                <TextBlock Text="Что даёт" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                                                                <TextBlock Text="Здесь появятся эффекты, бонусы и влияние навыка на персонажа." TextWrapping="Wrap"/>
                                                                <TextBlock Text="Требования и доступность" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
