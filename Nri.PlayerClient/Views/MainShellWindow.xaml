<Window x:Class="Nri.PlayerClient.Views.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Nri.PlayerClient.Views.Controls"
        mc:Ignorable="d"
        Title="NRI Player"
        Height="900"
        Width="1440"
        MinHeight="740"
        MinWidth="1180">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="230"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="NRI / Player" FontWeight="Bold" FontSize="18" Margin="0,0,16,0"/>
                    <Border Style="{StaticResource StatusBadgeStyle}" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ConnectionState}" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="{Binding SessionSummary}" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource CardStyle}" Padding="8,4">
                        <TextBlock Text="{Binding AudioStateText}" Width="260" TextTrimming="CharacterEllipsis" Foreground="{StaticResource MutedBrush}"/>
                    </Border>
                    <Button Content="Обновить" Command="{Binding RefreshCommand}"/>
                    <Button x:Name="AuthButton" Content="Войти" Command="{Binding ToggleAuthPopupCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Border Style="{StaticResource CardStyle}" Padding="8,4" Margin="8,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAuthenticated}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding PlayerDisplayName}" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,8">
            <Grid>
                <TabControl>
                    <TabItem Header="Мои персонажи">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <ListBox x:Name="MyCharactersList" ItemsSource="{Binding MyCharacters}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                                        <TextBlock Text="{Binding Race, StringFormat=Раса: {0}}" Foreground="{StaticResource MutedBrush}"/>
                                                        <TextBlock Text="{Binding Age, StringFormat=Возраст: {0}}" Foreground="{StaticResource MutedBrush}"/>
                                                        <TextBlock Text="{Binding Description}" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                                                        <Border Style="{StaticResource CardStyle}" Padding="6,2">
                                                            <TextBlock Text="{Binding IsActive, StringFormat=Активен: {0}}"/>
                                                        </Border>
                                                        <Border Style="{StaticResource CardStyle}" Padding="6,2">
                                                            <TextBlock Text="{Binding Archived, StringFormat=Архив: {0}}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Style="{StaticResource CardStyle}"
                                        Background="{StaticResource PanelAltBrush}"
                                        Padding="18"
                                        Width="380"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=MyCharactersList, Path=HasItems}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="Персонажи" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Список персонажей не загружен" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Нет доступных персонажей" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Подключитесь к серверу или выберите сессию" Foreground="{StaticResource MutedBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Выбранный персонаж" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <ComboBox SelectedValuePath="Id"
                                                  DisplayMemberPath="Name"
                                                  SelectedValue="{Binding SelectedCharacterId, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding MyCharacters}"/>
                                        <Button Content="Загрузить детали" Command="{Binding LoadCharacterDetailsCommand}" Margin="0,8,0,0"/>
                                        <Button Content="Загрузить visibility" Command="{Binding VisibilityLoadCommand}"/>
                                        <TextBlock Text="Настройка скрываемости" FontWeight="Bold" Margin="0,8,0,4"/>
                                        <CheckBox Content="Скрывать описание" IsChecked="{Binding VisHideDescription}"/>
                                        <CheckBox Content="Скрывать предысторию" IsChecked="{Binding VisHideBackstory}"/>
                                        <CheckBox Content="Скрывать характеристики" IsChecked="{Binding VisHideStats}"/>
                                        <CheckBox Content="Скрывать репутацию" IsChecked="{Binding VisHideReputation}"/>
                                        <Button Content="Сохранить visibility" Command="{Binding VisibilitySaveCommand}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Публичный вид другого персонажа" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBox Text="{Binding PublicViewCharacterId, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Content="Загрузить public view" Command="{Binding PublicCharacterLoadCommand}" Margin="0,6,0,0"/>
                                        <Grid Height="130" Margin="0,6,0,0">
                                            <ListBox x:Name="PublicCharacterRowsList" ItemsSource="{Binding PublicCharacterRows}"/>
                                            <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Padding="14" IsHitTestVisible="False">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ElementName=PublicCharacterRowsList, Path=HasItems}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Публичный профиль" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Нет данных" FontWeight="SemiBold" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Данные ещё не загружены" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Подключитесь к серверу, чтобы увидеть содержимое" Foreground="{StaticResource MutedBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Активный персонаж">
                        <Grid Margin="8">
                            <TabControl>
                                <TabItem Header="Обзор">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <Grid Margin="4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding CharacterNameDisplay}" FontSize="22" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding CharacterRaceDisplay, StringFormat=Раса: {0}}" Foreground="{StaticResource MutedBrush}"/>
                                                        <TextBlock Text="{Binding CharacterAgeDisplay, StringFormat=Возраст: {0}}" Foreground="{StaticResource MutedBrush}"/>
                                                        <TextBlock Text="{Binding CharacterHeightDisplay, StringFormat=Рост: {0}}" Foreground="{StaticResource MutedBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="Описание" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding CharacterDescriptionDisplay}" Margin="0,0,0,8"/>
                                                        <TextBlock Text="Предыстория" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding CharacterBackstoryDisplay}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Характеристики" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                            <StackPanel>
                                                                <TextBlock Text="Боевая группа" FontWeight="Bold" Margin="0,0,0,6"/>
                                                                <ItemsControl ItemsSource="{Binding CoreStatRows}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <DockPanel Margin="0,2,0,2">
                                                                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedBrush}" DockPanel.Dock="Left"/>
                                                                                <TextBlock Text="{Binding Value}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                                            </DockPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                            <StackPanel>
                                                                <TextBlock Text="Атрибуты" FontWeight="Bold" Margin="0,0,0,6"/>
                                                                <ItemsControl ItemsSource="{Binding AttributeStatRows}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <DockPanel Margin="0,2,0,2">
                                                                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedBrush}" DockPanel.Dock="Left"/>
                                                                                <TextBlock Text="{Binding Value}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                                            </DockPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="3*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Деньги" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                                                        <ItemsControl ItemsSource="{Binding MoneyRows}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <UniformGrid Columns="4"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                            <Ellipse Width="12" Height="12" Fill="{Binding Color}" Margin="0,0,6,0"/>
                                                                            <TextBlock Text="{Binding Name}" Width="95"/>
                                                                            <TextBlock Text="{Binding Amount}" FontWeight="SemiBold"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="8,0,0,0">
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="Монеты опыта" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                                                            <TextBlock Text="0" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="Система ещё не подключена" Foreground="{StaticResource MutedBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Инвентарь (preview)" FontWeight="Bold"/>
                                                        <ItemsControl ItemsSource="{Binding InventoryRows}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="Владения (preview)" FontWeight="Bold"/>
                                                        <ItemsControl ItemsSource="{Binding HoldingsRows}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Компаньоны (preview)" FontWeight="Bold"/>
                                                        <ItemsControl ItemsSource="{Binding Companions}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Name}"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Header="Инвентарь">
                                    <ListBox ItemsSource="{Binding InventoryRows}"/>
                                </TabItem>

                                <TabItem Header="Владения">
                                    <ListBox ItemsSource="{Binding HoldingsRows}"/>
                                </TabItem>

                                <TabItem Header="Репутация">
                                    <ListBox ItemsSource="{Binding ReputationRows}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CardStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="180"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="60"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                                        <Grid Grid.Column="1" Height="18" VerticalAlignment="Center">
                                                            <Border Background="{StaticResource ReputationGradient}" CornerRadius="9"/>
                                                            <ProgressBar Minimum="-100" Maximum="100" Value="{Binding Value}" Foreground="#22000000" Background="Transparent"/>
                                                        </Grid>
                                                        <TextBlock Grid.Column="2" Text="{Binding Value}" HorizontalAlignment="Right" FontWeight="Bold"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </TabItem>

                                <TabItem Header="Компаньоны">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="280"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ListBox x:Name="CompanionList"
                                                 ItemsSource="{Binding Companions}"
                                                 SelectedItem="{Binding SelectedCompanion, Mode=TwoWay}"
                                                 DisplayMemberPath="NameDisplay"/>
                                        <TabControl Grid.Column="1" Margin="8,0,0,0" DataContext="{Binding SelectedCompanion}">
                                            <TabItem Header="Обзор">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <Grid Margin="4">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="2*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding NameDisplay}" FontSize="22" FontWeight="Bold"/>
                                                                    <TextBlock Text="{Binding SpeciesDisplay, StringFormat=Вид: {0}}" Foreground="{StaticResource MutedBrush}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="Описание" FontWeight="Bold"/>
                                                                    <TextBlock Text="{Binding NotesDisplay}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                                                            <StackPanel>
                                                                <TextBlock Text="Характеристики" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                                        <StackPanel>
                                                                            <TextBlock Text="Боевая группа" FontWeight="Bold" Margin="0,0,0,6"/>
                                                                            <ItemsControl ItemsSource="{Binding CoreStatRows}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <DockPanel Margin="0,2,0,2">
                                                                                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedBrush}" DockPanel.Dock="Left"/>
                                                                                            <TextBlock Text="{Binding Value}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                                                        </DockPanel>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                                        <StackPanel>
                                                                            <TextBlock Text="Атрибуты" FontWeight="Bold" Margin="0,0,0,6"/>
                                                                            <ItemsControl ItemsSource="{Binding AttributeStatRows}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <DockPanel Margin="0,2,0,2">
                                                                                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedBrush}" DockPanel.Dock="Left"/>
                                                                                            <TextBlock Text="{Binding Value}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                                                        </DockPanel>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                                                            <StackPanel>
                                                                <TextBlock Text="Инвентарь" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                                                                <TextBlock Text="Содержимое инвентаря" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                                                <ListBox ItemsSource="{Binding InventoryRows}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </ScrollViewer>
                                            </TabItem>
                                            <TabItem Header="Владения">
                                                <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                    <StackPanel>
                                                        <TextBlock Text="Владения компаньона" FontWeight="Bold" FontSize="16"/>
                                                        <TextBlock Text="Данные по владениям" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8"/>
                                                        <ListBox ItemsSource="{Binding HoldingsRows}"/>
                                                    </StackPanel>
                                                </Border>
                                            </TabItem>
                                            <TabItem Header="Навыки">
                                                <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                    <StackPanel>
                                                        <TextBlock Text="Навыки компаньона" FontWeight="Bold" FontSize="16"/>
                                                        <TextBlock Text="Данные ещё не загружены" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8"/>
                                                        <ListBox ItemsSource="{Binding SkillsRows}"/>
                                                    </StackPanel>
                                                </Border>
                                            </TabItem>
                                            <TabItem Header="Классы">
                                                <StackPanel>
                                                    <TextBlock Text="Классовая схема компаньона" Foreground="{StaticResource MutedBrush}"/>
                                                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                        <controls:ClassHexDirectionView Height="280" Margin="8"/>
                                                    </Border>
                                                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                        <StackPanel>
                                                            <TextBlock Text="Классы компаньона" FontWeight="Bold" FontSize="16"/>
                                                            <TextBlock Text="Классы компаньона пока не загружены" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8"/>
                                                            <ListBox ItemsSource="{Binding ClassRows}" MinHeight="84"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </TabItem>
                                        </TabControl>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="Навыки">
                                    <TabControl>
                                        <TabItem Header="Справочник навыков">
                                            <ListBox ItemsSource="{Binding SkillCatalogRows}"/>
                                        </TabItem>
                                        <TabItem Header="Навыки персонажа/компаньона">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Width="220" Text="{Binding SelectedSkillId, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <Button Content="Получить навык" Command="{Binding AcquireSkillCommand}"/>
                                                </StackPanel>
                                                <ListBox Grid.Row="1" ItemsSource="{Binding SkillRows}">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                                    <Setter Property="Opacity" Value="0.6"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                </ListBox>
                                            </Grid>
                                        </TabItem>
                                    </TabControl>
                                </TabItem>

                                <TabItem Header="Классы">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Width="220" Text="{Binding SelectedClassNodeId, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Content="Получить класс" Command="{Binding AcquireClassNodeCommand}"/>
                                        </StackPanel>
                                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,0" Background="{StaticResource PanelAltBrush}">
                                            <controls:ClassHexDirectionView Height="300" Margin="8"/>
                                        </Border>
                                        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,8,0,0" Background="{StaticResource PanelAltBrush}">
                                            <StackPanel>
                                                <TextBlock Text="Ветви классов" FontWeight="Bold" FontSize="16"/>
                                                <TextBlock Text="Классы персонажа пока не загружены" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8"/>
                                                <TextBlock Text="Здесь позже появятся реальные ветви и доступные классы по каждому направлению." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                                <ItemsControl ItemsSource="{Binding ClassNodes}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource CardStyle}" Background="#FF223452" Margin="0,0,0,6">
                                                                <DockPanel>
                                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                                                    <Button Content="Выбрать"
                                                                            Command="{Binding DataContext.AcquireClassNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding NodeId}"
                                                                            HorizontalAlignment="Right"/>
                                                                </DockPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,4">
                        <ListBox ItemsSource="{Binding GameFeedRows}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}" Padding="8" Margin="0,0,0,3">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                                <Setter Property="Background" Value="#FF1E2A40"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Chat"><Setter Property="Background" Value="#FF1F314A"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="System"><Setter Property="Background" Value="#FF31263E"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Dice"><Setter Property="Background" Value="#FF2B3B2D"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Request"><Setter Property="Background" Value="#FF3A2C2C"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Kind}" Width="72" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <ComboBox Width="160" ItemsSource="{Binding ChatTypeOptions}" SelectedItem="{Binding ChatTypeInput}"/>
                        <TextBox Width="430" Text="{Binding ChatTextInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Отправить" Command="{Binding ChatSendCommand}"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1" Margin="8,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Заявка на бросок" FontWeight="Bold" Margin="0,0,0,6"/>
                            <WrapPanel>
                                <TextBlock Text="Кубов" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox Width="60" Text="{Binding DiceCount, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="Грани" VerticalAlignment="Center" Margin="6,0,4,0"/>
                                <TextBox Width="70" Text="{Binding DiceFaces, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="Мод." VerticalAlignment="Center" Margin="6,0,4,0"/>
                                <TextBox Width="60" Text="{Binding DiceModifier, UpdateSourceTrigger=PropertyChanged}"/>
                            </WrapPanel>
                            <WrapPanel>
                                <ComboBox Width="130" ItemsSource="{Binding DiceVisibilityOptions}" SelectedItem="{Binding DiceVisibilityInput}"/>
                                <TextBox Width="210" Text="{Binding DiceDescriptionInput, UpdateSourceTrigger=PropertyChanged}"/>
                            </WrapPanel>
                            <WrapPanel>
                                <TextBox Width="200" Text="{Binding SelectedRequestId, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Content="Создать" Command="{Binding CreateDiceRequestCommand}"/>
                                <Button Content="Отменить" Command="{Binding CancelRequestCommand}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Состояние сессии" FontWeight="Bold"/>
                            <ItemsControl ItemsSource="{Binding SessionStateRows}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Музыка" FontWeight="Bold"/>
                            <TextBlock Text="{Binding AudioStateText}" Margin="0,4,0,6"/>
                            <WrapPanel>
                                <TextBlock Text="Громкость" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Slider Width="120" Minimum="0" Maximum="1" Value="{Binding LocalVolume, UpdateSourceTrigger=PropertyChanged}"/>
                                <CheckBox Content="Mute" IsChecked="{Binding LocalMuted}" Margin="8,0,0,0"/>
                            </WrapPanel>
                            <Button Content="Применить" Command="{Binding AudioApplyLocalSettingsCommand}" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Заметки" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Личные заметки и советы админов" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                            <WrapPanel>
                                <ComboBox Width="120" ItemsSource="{Binding NoteTargetTypeOptions}" SelectedItem="{Binding NoteTargetType}"/>
                                <TextBox Width="120" Text="{Binding NoteTargetId, UpdateSourceTrigger=PropertyChanged}"/>
                                <ComboBox Width="130" ItemsSource="{Binding NoteVisibilityOptions}" SelectedItem="{Binding NoteVisibility}"/>
                            </WrapPanel>
                            <TextBox Text="{Binding NoteTitle, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Text="{Binding NoteText, UpdateSourceTrigger=PropertyChanged}" Height="58" AcceptsReturn="True"/>
                            <WrapPanel>
                                <Button Content="Обновить" Command="{Binding NotesRefreshCommand}"/>
                                <Button Content="Создать" Command="{Binding NotesCreateCommand}"/>
                                <TextBox Width="120" Text="{Binding SelectedNoteId, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Content="Архивировать" Command="{Binding NotesArchiveCommand}"/>
                            </WrapPanel>
                            <TextBlock Text="Мои заметки" FontWeight="SemiBold" Margin="0,6,0,2"/>
                            <ListBox ItemsSource="{Binding NoteRows}" Height="52"/>
                            <TextBlock Text="Советы от админов" FontWeight="SemiBold" Margin="0,6,0,2"/>
                            <ListBox ItemsSource="{Binding AdminNoteRows}" Height="52"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Popup IsOpen="{Binding IsAuthPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=AuthButton}" StaysOpen="False">
            <Border Style="{StaticResource CardStyle}" Width="320" Background="{StaticResource PanelAltBrush}">
                <StackPanel>
                    <TextBlock Text="Авторизация" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                    <TextBlock Text="Логин"/>
                    <TextBox Text="{Binding LoginText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Пароль"/>
                    <PasswordBox x:Name="AuthPasswordBox" PasswordChanged="OnAuthPasswordChanged"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Регистрация" Command="{Binding RegisterCommand}"/>
                        <Button Content="Вход" Command="{Binding LoginCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
