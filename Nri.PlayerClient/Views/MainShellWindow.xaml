                                                                <ListBoxItem>Архимаг Идрас</ListBoxItem>
                                                                <ListBoxItem>Леди Марен</ListBoxItem>
                                                                <ListBoxItem>Инженер Торвик</ListBoxItem>
                                                            </ListBox>
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Border>
                                                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="8,0,0,0">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <StackPanel>
                                                            <TextBlock Text="Карточка отношений с NPC" FontWeight="Bold" FontSize="16"/>
                                                            <TextBlock Text="{Binding ElementName=NpcRepList, Path=SelectedItem.Content, TargetNullValue=NPC не выбран}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                                            <Grid Height="20" Margin="0,10,0,0">
                                                                <Border Background="{StaticResource ReputationGradient}" CornerRadius="10"/>
                                                                <ProgressBar Minimum="-100" Maximum="100" Value="25" Background="Transparent"/>
                                                            </Grid>
                                                            <TextBlock Text="Причины отношения" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                                                            <TextBlock Text="В этой карточке появятся описание NPC, текущая шкала репутации и история ключевых причин изменения отношения." TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Grid>
                                        </TabItem>
                                    </TabControl>
                                </TabItem>

                                <TabItem Header="Компаньоны">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="280"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ListBox x:Name="CompanionList"
                                                 ItemsSource="{Binding Companions}"
                                                 SelectedItem="{Binding SelectedCompanion, Mode=TwoWay}"
                                                 DisplayMemberPath="NameDisplay"/>
                                        <TabControl Grid.Column="1" Margin="8,0,0,0" DataContext="{Binding SelectedCompanion}">
                                            <TabItem Header="Обзор">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <Grid Margin="4">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="2*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding NameDisplay}" FontSize="22" FontWeight="Bold"/>
                                                                    <TextBlock Text="{Binding SpeciesDisplay, StringFormat=Вид: {0}}" Foreground="{StaticResource MutedBrush}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="Описание" FontWeight="Bold"/>
                                                                    <TextBlock Text="{Binding NotesDisplay}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                                                            <StackPanel>
                                                                <TextBlock Text="Характеристики" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                                        <StackPanel>
                                                                            <TextBlock Text="Боевая группа" FontWeight="Bold" Margin="0,0,0,6"/>
                                                                            <ItemsControl ItemsSource="{Binding CoreStatRows}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <DockPanel Margin="0,2,0,2">
                                                                                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedBrush}" DockPanel.Dock="Left"/>
                                                                                            <TextBlock Text="{Binding Value}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                                                        </DockPanel>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                                        <StackPanel>
                                                                            <TextBlock Text="Атрибуты" FontWeight="Bold" Margin="0,0,0,6"/>
                                                                            <ItemsControl ItemsSource="{Binding AttributeStatRows}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <DockPanel Margin="0,2,0,2">
                                                                                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedBrush}" DockPanel.Dock="Left"/>
                                                                                            <TextBlock Text="{Binding Value}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                                                        </DockPanel>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                                                            <StackPanel>
                                                                <TextBlock Text="Инвентарь" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                                                                <TextBlock Text="Содержимое инвентаря" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                                                <ListBox ItemsSource="{Binding InventoryRows}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </ScrollViewer>
                                            </TabItem>
                                            <TabItem Header="Владения">
                                                <Grid Margin="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.1*"/>
                                                        <ColumnDefinition Width="1.4*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="Владения компаньона" FontWeight="Bold" FontSize="16"/>
                                                                <TextBlock Text="Список масштабируется и остаётся доступным при маленькой высоте окна." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                                <ListBox x:Name="CompanionHoldingsList" ItemsSource="{Binding HoldingsRows}"/>
                                                            </ScrollViewer>
                                                        </Grid>
                                                    </Border>
                                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="8,0,0,0">
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                            <StackPanel>
                                                                <TextBlock Text="Карточка владения" FontWeight="Bold" FontSize="16"/>
                                                                <TextBlock Text="{Binding ElementName=CompanionHoldingsList, Path=SelectedItem, TargetNullValue=Владение не выбрано}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                                                <TextBlock Text="Здесь будут тип, описание, владельцы и свойства владения компаньона." TextWrapping="Wrap" Margin="0,8,0,0"/>
                                                            </StackPanel>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Grid>
                                            </TabItem>
                                            <TabItem Header="Навыки">
                                                <Grid Margin="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.1*"/>
                                                        <ColumnDefinition Width="1.4*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="Навыки компаньона" FontWeight="Bold" FontSize="16"/>
                                                                <TextBlock Text="Список и карточка готовы под будущие реальные данные." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                                <ListBox x:Name="CompanionSkillsList" ItemsSource="{Binding SkillsRows}"/>
                                                            </ScrollViewer>
                                                        </Grid>
                                                    </Border>
                                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="8,0,0,0">
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                            <StackPanel>
                                                                <TextBlock Text="Карточка навыка" FontWeight="Bold" FontSize="16"/>
                                                                <TextBlock Text="{Binding ElementName=CompanionSkillsList, Path=SelectedItem, TargetNullValue=Навык не выбран}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                                                <TextBlock Text="Тип" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                                                                <TextBlock Text="Активный / пассивный / технический placeholder"/>
                                                                <TextBlock Text="Эффект и требования" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                                                                <TextBlock Text="Здесь позже появятся описание, эффекты, требования и причина недоступности навыка компаньона." TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Grid>
                                            </TabItem>
                                            <TabItem Header="Классы">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                            <StackPanel>
                                                                <TextBlock Text="Классовая схема компаньона" Foreground="{StaticResource MutedBrush}"/>
                                                                <controls:ClassHexDirectionView Height="280" Margin="8"
                                                                                            DirectionSelectCommand="{Binding DataContext.AcquireClassNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <Grid Grid.Row="1" Margin="0,8,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="1.1*"/>
                                                                <ColumnDefinition Width="1.1*"/>
                                                                <ColumnDefinition Width="1.4*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="*"/>
                                                                    </Grid.RowDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="Ветви направления" FontWeight="Bold" FontSize="16"/>
                                                                        <TextBlock Text="{Binding DataContext.SelectedClassDirectionDisplay, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8"/>
                                                                    </StackPanel>
                                                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                                        <ListBox ItemsSource="{Binding DataContext.ClassBranches, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                             SelectedItem="{Binding DataContext.SelectedClassBranch, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                                                            <ListBox.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <Border Style="{StaticResource CardStyle}" Background="#FF223452">
                                                                                        <StackPanel>
                                                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                                                                            <TextBlock Text="{Binding Summary}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                                                        </StackPanel>
                                                                                    </Border>
                                                                                </DataTemplate>
                                                                            </ListBox.ItemTemplate>
                                                                        </ListBox>
                                                                    </ScrollViewer>
                                                                </Grid>
                                                            </Border>
                                                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="8,0,0,0">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="*"/>
                                                                    </Grid.RowDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="Классы ветви" FontWeight="Bold" FontSize="16"/>
                                                                        <TextBlock Text="{Binding DataContext.SelectedClassBranchTitle, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8"/>
                                                                    </StackPanel>
                                                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                                        <ListBox ItemsSource="{Binding DataContext.ClassEntries, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                             SelectedItem="{Binding DataContext.SelectedClassEntry, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                                                            <ListBox.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <Border Style="{StaticResource CardStyle}" Background="#FF223452">
                                                                                        <StackPanel>
                                                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                                                                            <TextBlock Text="{Binding Summary}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                                                        </StackPanel>
                                                                                    </Border>
                                                                                </DataTemplate>
                                                                            </ListBox.ItemTemplate>
                                                                        </ListBox>
                                                                    </ScrollViewer>
                                                                </Grid>
                                                            </Border>
                                                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="8,0,0,0">
                                                                <StackPanel>
                                                                    <TextBlock Text="Карточка класса компаньона" FontWeight="Bold" FontSize="16"/>
                                                                    <TextBlock Text="{Binding DataContext.SelectedClassEntryTitle, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                                                    <TextBlock Text="{Binding DataContext.SelectedClassEntrySummary, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                                    <Border Style="{StaticResource CardStyle}" Background="#FF223452" Margin="0,10,0,0">
                                                                        <StackPanel>
                                                                            <TextBlock Text="Выбранное направление" Foreground="{StaticResource MutedBrush}"/>
                                                                            <TextBlock Text="{Binding DataContext.SelectedClassDirectionDisplay, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="SemiBold"/>
                                                                            <TextBlock Text="{Binding DataContext.SelectedClassEntryRequirements, RelativeSource={RelativeSource AncestorType=Window}}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <TextBlock Text="Классы компаньона пока остаются заглушкой до загрузки полного дерева развития с сервера." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </Grid>
                                                </ScrollViewer>
                                            </TabItem>
                                        </TabControl>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="Навыки">
