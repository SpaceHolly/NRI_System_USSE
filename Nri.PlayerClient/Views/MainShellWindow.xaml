                                                            <ListBox ItemsSource="{Binding ClassBranches}" SelectedItem="{Binding SelectedClassBranch, Mode=TwoWay}">
                                                                <ListBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Style="{StaticResource CardStyle}" Background="#FF223452">
                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                                                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
                                                                                <TextBlock Text="{Binding Summary}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ListBox.ItemTemplate>
                                                            </ListBox>
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Border>
                                                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="8,0,0,0">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="Классы выбранной ветви" FontWeight="Bold" FontSize="16"/>
                                                            <TextBlock Text="{Binding SelectedClassBranchTitle}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8"/>
                                                        </StackPanel>
                                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                            <ListBox ItemsSource="{Binding ClassEntries}" SelectedItem="{Binding SelectedClassEntry, Mode=TwoWay}">
                                                                <ListBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Style="{StaticResource CardStyle}" Background="#FF223452">
                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                                                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
                                                                                <TextBlock Text="{Binding Summary}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ListBox.ItemTemplate>
                                                            </ListBox>
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Border>
                                                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="8,0,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Карточка класса" FontWeight="Bold" FontSize="16"/>
                                                        <TextBlock Text="{Binding SelectedClassEntryTitle}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                                        <TextBlock Text="{Binding SelectedClassEntrySummary}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                        <Border Style="{StaticResource CardStyle}" Background="#FF223452" Margin="0,10,0,0">
                                                            <StackPanel>
                                                                <TextBlock Text="Направление" Foreground="{StaticResource MutedBrush}"/>
                                                                <TextBlock Text="{Binding SelectedClassDirectionDisplay}" FontWeight="SemiBold"/>
                                                                <TextBlock Text="Ветвь" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                                                                <TextBlock Text="{Binding SelectedClassBranchTitle}" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding SelectedClassEntryRequirements}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Text="Панель готова к масштабированию: вместо плоского списка здесь останется контекстная навигация по направлению, ветви и конкретному классу." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <Border Style="{StaticResource CardStyle}" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Чат игрока" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="Чат открыт как отдельное рабочее окно с большой историей сообщений и удобным вводом." Margin="0,6,0,8" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"/>
                            <Button Content="Открыть окно чата" Click="OpenChatWindow" Height="34"/>
                            <TextBlock Margin="0,8,0,0" Text="{Binding ChatSummary}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Column="1" Margin="8,0,8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Создание персонажа" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="Форма создания персонажа вынесена в отдельное окно: имя, раса и предыстория." Margin="0,6,0,8" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"/>
                                <Button Content="Открыть форму создания" Click="OpenCharacterCreateWindow" Height="34"/>
                                <TextBlock Margin="0,8,0,0" Text="{Binding ConnectionStatusDetail}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Бросок кубиков" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="Отдельная зона бросков. Режим: Обычный — в общую историю, Тестовый — личный тест." Margin="0,4,0,6" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                <WrapPanel>
                                    <TextBlock Text="Режим" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <ComboBox Width="100" ItemsSource="{Binding DiceModeOptions}" SelectedItem="{Binding DiceModeInput}"/>
                                    <TextBlock Text="Формула" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                    <TextBox Width="36" Text="{Binding DiceCount, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="d" VerticalAlignment="Center"/>
                                    <TextBox Width="46" Text="{Binding DiceFaces, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Width="56" Margin="6,0,0,0" Text="{Binding DiceModifier, UpdateSourceTrigger=PropertyChanged}" ToolTip="Модификатор"/>
                                </WrapPanel>
                                <WrapPanel Margin="0,6,0,0">
                                    <TextBlock Text="Видимость" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <ComboBox Width="130" ItemsSource="{Binding DiceVisibilityOptions}" SelectedItem="{Binding DiceVisibilityInput}"/>
                                    <Button Margin="6,0,0,0" Content="Бросить" Command="{Binding CreateDiceRequestCommand}"/>
                                </WrapPanel>
                                <TextBox Margin="0,6,0,0" Text="{Binding DiceDescriptionInput, UpdateSourceTrigger=PropertyChanged}" ToolTip="Описание броска"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Состояние сессии" FontWeight="Bold"/>
                            <ItemsControl ItemsSource="{Binding SessionStateRows}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Музыка" FontWeight="Bold"/>
                            <TextBlock Text="{Binding AudioStateText}" Margin="0,4,0,6"/>
                            <WrapPanel>
                                <TextBlock Text="Громкость" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Slider Width="120" Minimum="0" Maximum="1" Value="{Binding LocalVolume, UpdateSourceTrigger=PropertyChanged}"/>
                                <CheckBox Content="Mute" IsChecked="{Binding LocalMuted}" Margin="8,0,0,0"/>
                            </WrapPanel>
                            <Button Content="Применить" Command="{Binding AudioApplyLocalSettingsCommand}" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Заметки" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="Личные заметки и советы админов" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <WrapPanel>
                                    <ComboBox Width="120" ItemsSource="{Binding NoteTargetTypeOptions}" SelectedItem="{Binding NoteTargetType}"/>
                                    <TextBox Width="120" Text="{Binding NoteTargetId, UpdateSourceTrigger=PropertyChanged}"/>
                                    <ComboBox Width="130" ItemsSource="{Binding NoteVisibilityOptions}" SelectedItem="{Binding NoteVisibility}"/>
                                </WrapPanel>
                                <TextBox Text="{Binding NoteTitle, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Text="{Binding NoteText, UpdateSourceTrigger=PropertyChanged}" Height="58" AcceptsReturn="True"/>
                                <WrapPanel>
                                    <Button Content="Обновить" Command="{Binding NotesRefreshCommand}"/>
                                    <Button Content="Создать" Command="{Binding NotesCreateCommand}"/>
                                    <TextBox Width="120" Text="{Binding SelectedNoteId, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Content="Архивировать" Command="{Binding NotesArchiveCommand}"/>
                                </WrapPanel>
                                <TextBlock Text="Мои заметки" FontWeight="SemiBold" Margin="0,6,0,2"/>
                                <ListBox ItemsSource="{Binding NoteRows}" Height="52"/>
                                <TextBlock Text="Советы от админов" FontWeight="SemiBold" Margin="0,6,0,2"/>
                                <ListBox ItemsSource="{Binding AdminNoteRows}" Height="52"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Border>
        </StackPanel>
        </ScrollViewer>

        <Popup IsOpen="{Binding IsConnectionPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=ConnectionButton}" StaysOpen="False">
            <Border Style="{StaticResource CardStyle}" Width="360" Background="{StaticResource PanelAltBrush}">
                <StackPanel>
                    <TextBlock Text="Подключение к серверу" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                    <TextBlock Text="IPv4 / адрес сервера"/>
                    <TextBox Text="{Binding ServerHostInput, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Порт" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding ServerPortInput, UpdateSourceTrigger=PropertyChanged}"/>
                    <Border Style="{StaticResource CardStyle}" Background="#FF223452" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Текущий статус" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ConnectionState}" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding ConnectionStatusDetail}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Последнее сохранённое подключение" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding LastServerHost}"/>
                    <TextBlock Text="{Binding LastServerPort}" Foreground="{StaticResource MutedBrush}"/>
                    <WrapPanel Margin="0,10,0,0">
                        <Button Content="Подключиться" Command="{Binding ConnectToServerCommand}"/>
                        <Button Content="Применить" Command="{Binding ApplyConnectionSettingsCommand}"/>
                        <Button Content="Сбросить к localhost" Command="{Binding ResetConnectionDefaultsCommand}"/>
                        <Button Content="Последний адрес" Command="{Binding UseLastConnectionCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Popup>

        <Popup IsOpen="{Binding IsAuthPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=AuthButton}" StaysOpen="False">
            <Border Style="{StaticResource CardStyle}" Width="320" Background="{StaticResource PanelAltBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Авторизация" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                    <TextBlock Text="Логин"/>
                    <TextBox Text="{Binding LoginText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Пароль"/>
                    <PasswordBox x:Name="AuthPasswordBox" PasswordChanged="OnAuthPasswordChanged"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Регистрация" Command="{Binding RegisterCommand}"/>
                        <Button Content="Вход" Command="{Binding LoginCommand}"/>
                    </StackPanel>
                    <Separator Margin="0,10,0,10"/>
                    <TextBlock Text="Смена пароля" FontWeight="Bold"/>
                    <TextBlock Text="Старый пароль" Margin="0,6,0,0"/>
                    <TextBox Text="{Binding OldPasswordText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Новый пароль" Margin="0,6,0,0"/>
                    <TextBox Text="{Binding NewPasswordText, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Сменить пароль" Command="{Binding ChangePasswordCommand}" Margin="0,10,0,0"/>
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Popup>
    </Grid>
</Window>
