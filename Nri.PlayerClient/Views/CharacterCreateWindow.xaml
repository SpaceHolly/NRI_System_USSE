<Window x:Class="Nri.PlayerClient.Views.CharacterCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NRI Player — Создание персонажа"
        Width="720"
        Height="560"
        MinWidth="620"
        MinHeight="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="8">
            <StackPanel>
                <TextBlock Text="Создание персонажа" FontWeight="Bold" FontSize="17"/>
                <TextBlock Text="Заполните базовые параметры и отправьте создание персонажа." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,8" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Имя персонажа" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding CreateCharacterName, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="1" Text="Раса" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding CreateCharacterRace, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Text="Стартовые характеристики" VerticalAlignment="Center" Margin="0,12,0,0"/>
                <UniformGrid Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Columns="4">
                    <StackPanel Margin="0,0,8,0"><TextBlock Text="HP" Foreground="{StaticResource MutedBrush}"/><TextBox Text="{Binding CreateCharacterHealth, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <StackPanel Margin="0,0,8,0"><TextBlock Text="STR" Foreground="{StaticResource MutedBrush}"/><TextBox Text="{Binding CreateCharacterStrength, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <StackPanel Margin="0,0,8,0"><TextBlock Text="DEX" Foreground="{StaticResource MutedBrush}"/><TextBox Text="{Binding CreateCharacterDexterity, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <StackPanel><TextBlock Text="INT" Foreground="{StaticResource MutedBrush}"/><TextBox Text="{Binding CreateCharacterIntellect, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                </UniformGrid>

                <TextBlock Grid.Row="3" Text="Стартовые ресурсы" VerticalAlignment="Center" Margin="0,12,0,0"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,12,0,0">
                    <TextBlock Text="Железные монеты" Foreground="{StaticResource MutedBrush}"/>
                    <TextBox Width="180" Text="{Binding CreateCharacterIron, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <Border Grid.Row="4" Grid.ColumnSpan="2" Style="{StaticResource CardStyle}" Margin="0,12,0,0" Background="{StaticResource PanelAltBrush}">
                    <TextBlock Text="{Binding LastStatusMessage}" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8">
            <DockPanel>
                <Button DockPanel.Dock="Right" Width="200" Content="Создать персонажа" Command="{Binding CreateCharacterCommand}"/>
                <TextBlock Text="После успешного создания список персонажей будет обновлён автоматически." VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
