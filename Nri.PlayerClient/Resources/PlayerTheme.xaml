<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ColorBg">#FF171B26</Color>
    <Color x:Key="ColorPanel">#FF1F2533</Color>
    <Color x:Key="ColorPanelAlt">#FF252D3D</Color>
    <Color x:Key="ColorBorder">#FF313A4F</Color>
    <Color x:Key="ColorText">#FFE8ECF8</Color>
    <Color x:Key="ColorMuted">#FF9EA7BC</Color>
    <Color x:Key="ColorAccent">#FF4CA6FF</Color>
    <Color x:Key="ColorAccentStrong">#FF2C8FF2</Color>
    <Color x:Key="ColorSuccess">#FF4CD992</Color>
    <Color x:Key="ColorDanger">#FFF36A6A</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource ColorBg}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource ColorPanel}"/>
    <SolidColorBrush x:Key="PanelAltBrush" Color="{StaticResource ColorPanelAlt}"/>
    <SolidColorBrush x:Key="BorderBrushTheme" Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource ColorText}"/>
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource ColorMuted}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="AccentStrongBrush" Color="{StaticResource ColorAccentStrong}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ColorDanger}"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushTheme}"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushTheme}"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushTheme}"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushTheme}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
    </Style>

    <Style TargetType="Expander">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Margin" Value="0,4,0,4"/>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="Border" x:Key="CardStyle">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushTheme}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="4"/>
    </Style>

    <Style x:Key="StatusBadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsOnline}" Value="True">
                <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ClassNodeButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#FF475066"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushTheme}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="ToolTip" Value="{Binding State}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding State}" Value="Start">
                <Setter Property="Background" Value="#FF627FFF"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding State}" Value="Taken">
                <Setter Property="Background" Value="#FF39B57E"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding State}" Value="Available">
                <Setter Property="Background" Value="#FFB24A4A"/>
                <Setter Property="Opacity" Value="0.85"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding State}" Value="Locked">
                <Setter Property="Background" Value="#FF40485D"/>
                <Setter Property="Opacity" Value="0.65"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <LinearGradientBrush x:Key="ReputationGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFE25C5C" Offset="0"/>
        <GradientStop Color="#FFF3F6FF" Offset="0.5"/>
        <GradientStop Color="#FF5E8CFF" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
