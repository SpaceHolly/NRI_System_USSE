<Window x:Class="Nri.ChatClient.Views.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NRI Chat Client"
        Height="760"
        Width="560"
        MinHeight="700"
        MinWidth="520"
        MaxWidth="660">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="NRI / Chat Client" FontWeight="Bold" FontSize="18" Foreground="{StaticResource TextBrush}"/>
                        <Border Style="{StaticResource StatusBadgeStyle}" Margin="10,0,0,0">
                            <TextBlock Text="{Binding ConnectionState}" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding UserSummary}" Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock Text="{Binding StatusText}" Margin="0,2,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button x:Name="ConnectionButton" Content="Сервер" Command="{Binding ToggleConnectionPopupCommand}"/>
                    <Button x:Name="AuthButton" Content="Вход" Command="{Binding ToggleAuthPopupCommand}"/>
                    <Button x:Name="RegisterButton" Content="Регистрация" Command="{Binding ToggleRegisterPopupCommand}"/>
                    <Button x:Name="PasswordButton" Content="Пароль" Command="{Binding ToggleChangePasswordPopupCommand}"/>
                    <Button Content="Обновить" Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,0" Padding="8">
            <TabControl>
                <TabItem Header="Чат">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="0,0,0,8" Padding="8">
                            <ListBox x:Name="TimelineList"
                                     ItemsSource="{Binding MergedTimelineRows}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}" Background="#FF223452" Padding="9" Margin="0,0,0,6">
                                            <StackPanel>
                                                <TextBlock TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="{Binding Sender}" FontWeight="SemiBold"/>
                                                    <Run Text=": "/>
                                                    <Run Text="{Binding Text}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Timestamp}" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0"
                                         Text="{Binding ChatTextInput, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="72"
                                         MaxHeight="130"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         ToolTip="Введите сообщение"/>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="98"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding ChatTypeOptions}" SelectedItem="{Binding ChatTypeInput}"/>
                                    <Button Grid.Column="2" Content="Отправить" Command="{Binding SendChatCommand}" Height="32"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Броски">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                            <StackPanel>
                                <TextBlock Text="Панель броска" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="Обычный бросок уходит в общую ленту, тестовый — как тестовый результат." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8"/>

                                <WrapPanel>
                                    <TextBlock Text="Режим" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox Width="110" ItemsSource="{Binding DiceModeOptions}" SelectedItem="{Binding DiceModeInput}"/>
                                    <TextBlock Text="Формула" VerticalAlignment="Center" Margin="10,0,6,0"/>
                                    <TextBox Width="36" Text="{Binding DiceCount, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="d" VerticalAlignment="Center" Margin="4,0"/>
                                    <TextBox Width="44" Text="{Binding DiceFaces, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Width="56" Margin="6,0,0,0" Text="{Binding DiceModifier, UpdateSourceTrigger=PropertyChanged}" ToolTip="Модификатор"/>
                                </WrapPanel>

                                <WrapPanel Margin="0,6,0,0">
                                    <TextBlock Text="Видимость" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox Width="150" ItemsSource="{Binding DiceVisibilityOptions}" SelectedItem="{Binding DiceVisibilityInput}"/>
                                    <Button Content="Бросить" Command="{Binding RollDiceCommand}" Margin="8,0,0,0"/>
                                </WrapPanel>

                                <TextBox Margin="0,6,0,0" Text="{Binding DiceDescriptionInput, UpdateSourceTrigger=PropertyChanged}" ToolTip="Комментарий к броску"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Видимые броски" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                <ListBox Grid.Row="1" ItemsSource="{Binding DiceRows}" Margin="0,8,0,0" BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardStyle}" Background="#FF223452" Padding="8" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <TextBlock TextWrapping="Wrap">
                                                        <Run Text="{Binding Sender}" FontWeight="SemiBold"/>
                                                        <Run Text=": "/>
                                                        <Run Text="{Binding Text}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Timestamp}" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,4,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Мои последние броски" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                <ListBox Grid.Row="1" ItemsSource="{Binding MyLastRollRows}" Margin="0,8,0,0" BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardStyle}" Background="#FF223452" Padding="8" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <TextBlock TextWrapping="Wrap" Text="{Binding Text}"/>
                                                    <TextBlock Text="{Binding Timestamp}" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <Popup IsOpen="{Binding IsConnectionPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=ConnectionButton}" StaysOpen="False">
            <Border Style="{StaticResource CardStyle}" Width="340" Background="{StaticResource PanelAltBrush}">
                <StackPanel>
                    <TextBlock Text="Подключение" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Адрес"/>
                    <TextBox Text="{Binding ServerHostInput, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Порт" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding ServerPortInput, UpdateSourceTrigger=PropertyChanged}"/>
                    <Border Style="{StaticResource CardStyle}" Background="#FF223452" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Статус" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ConnectionState}" Margin="0,3,0,0"/>
                            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Button Content="Подключиться" Command="{Binding ConnectToServerCommand}" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Popup>

        <Popup IsOpen="{Binding IsAuthPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=AuthButton}" StaysOpen="False">
            <Border Style="{StaticResource CardStyle}" Width="320" Background="{StaticResource PanelAltBrush}">
                <StackPanel>
                    <TextBlock Text="Авторизация" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Логин"/>
                    <TextBox Text="{Binding LoginText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Пароль" Margin="0,6,0,0"/>
                    <PasswordBox x:Name="AuthPasswordBox" PasswordChanged="OnAuthPasswordChanged"/>
                    <Button Content="Войти" Command="{Binding LoginCommand}" Margin="0,10,0,0"/>
                    <WrapPanel Margin="0,8,0,0">
                        <Button Content="Регистрация" Command="{Binding ToggleRegisterPopupCommand}"/>
                        <Button Content="Смена пароля" Command="{Binding ToggleChangePasswordPopupCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Popup>

        <Popup IsOpen="{Binding IsRegisterPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=RegisterButton}" StaysOpen="False">
            <Border Style="{StaticResource CardStyle}" Width="320" Background="{StaticResource PanelAltBrush}">
                <StackPanel>
                    <TextBlock Text="Регистрация" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Логин"/>
                    <TextBox Text="{Binding RegisterLoginText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Пароль" Margin="0,6,0,0"/>
                    <PasswordBox x:Name="RegisterPasswordBox" PasswordChanged="OnRegisterPasswordChanged"/>
                    <Button Content="Зарегистрировать" Command="{Binding RegisterCommand}" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Popup>

        <Popup IsOpen="{Binding IsChangePasswordPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=PasswordButton}" StaysOpen="False">
            <Border Style="{StaticResource CardStyle}" Width="320" Background="{StaticResource PanelAltBrush}">
                <StackPanel>
                    <TextBlock Text="Смена пароля" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Старый пароль"/>
                    <TextBox Text="{Binding OldPasswordText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Новый пароль" Margin="0,6,0,0"/>
                    <TextBox Text="{Binding NewPasswordText, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Сменить пароль" Command="{Binding ChangePasswordCommand}" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
