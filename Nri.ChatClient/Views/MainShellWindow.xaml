<Window x:Class="Nri.ChatClient.Views.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NRI Chat Client"
        Height="760"
        Width="980"
        MinHeight="680"
        MinWidth="900">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="NRI / Chat" FontWeight="Bold" FontSize="18" Margin="0,0,12,0"/>
                    <Border Style="{StaticResource StatusBadgeStyle}">
                        <TextBlock Text="{Binding ConnectionState}" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="{Binding StatusText}" Margin="12,0,0,0" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" Width="340"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox Width="130" Text="{Binding ServerHostInput, UpdateSourceTrigger=PropertyChanged}" ToolTip="Host"/>
                    <TextBox Width="70" Text="{Binding ServerPortInput, UpdateSourceTrigger=PropertyChanged}" ToolTip="Port"/>
                    <TextBox Width="140" Text="{Binding LoginText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Login"/>
                    <PasswordBox x:Name="PasswordInput" Width="140" PasswordChanged="PasswordInput_OnPasswordChanged" ToolTip="Password"/>
                    <Button Content="Войти" Command="{Binding LoginCommand}"/>
                    <Button Content="Обновить" Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,10,0,0" Padding="8">
            <TabControl>
                <TabItem Header="Чат">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="TimelineList" ItemsSource="{Binding MergedTimelineRows}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,8">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}" Padding="10" Margin="0,0,0,6">
                                        <StackPanel>
                                            <TextBlock TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="{Binding Sender}" FontWeight="SemiBold"/>
                                                <Run Text=": "/>
                                                <Run Text="{Binding Text}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Timestamp}" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBox Grid.Row="0" Text="{Binding ChatTextInput, UpdateSourceTrigger=PropertyChanged}" MinHeight="60" MaxHeight="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding ChatTypeOptions}" SelectedItem="{Binding ChatTypeInput}"/>
                                    <Button Grid.Column="2" Content="Отправить" Command="{Binding SendChatCommand}" Height="32"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Броски">
                    <Grid Margin="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Формула" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding DiceFormulaInput, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Видимость" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding DiceVisibilityOptions}" SelectedItem="{Binding DiceVisibilityInput}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Комментарий" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding DiceDescriptionInput, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10,0,0,0">
                                    <CheckBox Content="Тест" IsChecked="{Binding IsTestRoll}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Content="Бросить" Command="{Binding RollDiceCommand}" Height="32" MinWidth="90"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Мои последние броски" FontWeight="Bold" FontSize="14"/>
                                <ListBox Grid.Row="1" ItemsSource="{Binding MyLastRollRows}" Margin="0,8,0,0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,6" Padding="8">
                                                <StackPanel>
                                                    <TextBlock TextWrapping="Wrap">
                                                        <Run Text="{Binding Text}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Timestamp}" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
