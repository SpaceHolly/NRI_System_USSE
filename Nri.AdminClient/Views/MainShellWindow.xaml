                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" Style="{StaticResource SummaryMetricCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Сессия" Style="{StaticResource TitleTextStyle}"/>
                                            <TextBlock Text="{Binding LoginState}"/>
                                            <TextBlock Text="{Binding ChatSummary}"/>
                                            <TextBlock Text="{Binding AudioSummary}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Сводка подключения" Style="{StaticResource SectionTitleTextStyle}"/>
                                            <TextBlock Text="{Binding ConnectionStatusDetail}" Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding LastStatusMessage}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding SectionAccessHint}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Требует внимания" Style="{StaticResource SectionTitleTextStyle}"/>
                                            <TextBlock Text="{Binding PendingRequestsCount, StringFormat=Заявок на модерацию: {0}}" Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding LocksCount, StringFormat=Активных блокировок: {0}}"/>
                                            <TextBlock Text="{Binding PendingAccountsCount, StringFormat=Ожидают подтверждения: {0}}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Последние важные события" Style="{StaticResource SectionTitleTextStyle}"/>
                                        <ListBox ItemsSource="{Binding OverviewActivityRows}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Люди" Tag="Люди">
                        <Grid Margin="8" IsEnabled="{Binding ArePrivilegedSectionsEnabled}">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Ожидают подтверждения" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding PendingAccountsCount}" FontSize="22"/></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Игроки онлайн" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding ActivePlayersCount}" FontSize="22"/></StackPanel></Border>
                                <Border Grid.Column="2" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Активные блокировки" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding LocksCount}" FontSize="22"/></StackPanel></Border>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,0,8,0">
                                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <DockPanel><TextBlock Text="Ожидающие аккаунты" Style="{StaticResource SectionTitleTextStyle}"/><Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding RefreshPeopleSectionCommand}" IsEnabled="{Binding IsIdle}"/></DockPanel>
                                            <DataGrid ItemsSource="{Binding PendingAccounts}" SelectedValuePath="Id" SelectedValue="{Binding SelectedPendingAccountId, UpdateSourceTrigger=PropertyChanged}" MinHeight="180">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="AccountId" Binding="{Binding Id}" Width="2.1*"/>
                                                    <DataGridTextColumn Header="Login" Binding="{Binding Name}" Width="1.4*"/>
                                                    <DataGridTextColumn Header="Status" Binding="{Binding State}" Width="1.2*"/>
                                                    <DataGridTextColumn Header="Created" Binding="{Binding Extra}" Width="1.5*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <WrapPanel Margin="0,8,0,0"><Button Content="Подтвердить" Command="{Binding ApproveCommand}" IsEnabled="{Binding CanManagePendingAccount}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Архивировать" Command="{Binding ArchiveCommand}" IsEnabled="{Binding CanManagePendingAccount}"/></WrapPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Игроки" Style="{StaticResource SectionTitleTextStyle}"/><DataGrid ItemsSource="{Binding Players}" SelectedValuePath="Id" SelectedValue="{Binding SelectedOwnerUserId, UpdateSourceTrigger=PropertyChanged}" MinHeight="180"><DataGrid.Columns><DataGridTextColumn Header="UserId" Binding="{Binding Id}" Width="2*"/><DataGridTextColumn Header="Login" Binding="{Binding Name}" Width="1.5*"/><DataGridTextColumn Header="Status" Binding="{Binding State}" Width="1.2*"/><DataGridTextColumn Header="Presence" Binding="{Binding Extra}" Width="1.5*"/></DataGrid.Columns></DataGrid><WrapPanel Margin="0,8,0,0"><Button Content="Загрузить персонажей" Command="{Binding OpenPlayerCharactersCommand}" IsEnabled="{Binding CanLoadPlayerCharacters}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Открыть раздел персонажей" Command="{Binding SelectSectionCommand}" CommandParameter="Персонажи" IsEnabled="{Binding CanLoadPlayerCharacters}"/></WrapPanel></StackPanel></Border>
                                </Grid>
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8"><StackPanel><DockPanel><TextBlock Text="Персонажи" Style="{StaticResource SectionTitleTextStyle}"/><Button DockPanel.Dock="Right" Content="Обновить" Style="{StaticResource GhostButtonStyle}" Command="{Binding LoadOwnerCharactersCommand}"/></DockPanel><TextBox Margin="0,8,0,6" Text="{Binding CharactersSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Поиск по имени, id, расе"/><DataGrid ItemsSource="{Binding FilteredCharacters}" SelectedValuePath="Id" SelectedValue="{Binding SelectedCharacterId, UpdateSourceTrigger=PropertyChanged}" MinHeight="190"><DataGrid.Columns><DataGridTextColumn Header="CharacterId" Binding="{Binding Id}" Width="2*"/><DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="1.4*"/><DataGridTextColumn Header="Профиль" Binding="{Binding Extra}" Width="1.6*"/></DataGrid.Columns></DataGrid></StackPanel></Border>
                                    <Border Grid.Row="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Блокировки" Style="{StaticResource SectionTitleTextStyle}"/><TextBox Margin="0,8,0,6" Text="{Binding LocksSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Поиск по владельцу, id или причине"/><DataGrid ItemsSource="{Binding FilteredLockRows}" SelectedValuePath="Id" SelectedValue="{Binding SelectedLockId, UpdateSourceTrigger=PropertyChanged}" MinHeight="190"><DataGrid.Columns><DataGridTextColumn Header="CharacterId" Binding="{Binding Id}" Width="2*"/><DataGridTextColumn Header="Владелец" Binding="{Binding Name}" Width="1.4*"/><DataGridTextColumn Header="Описание" Binding="{Binding Extra}" Width="2*"/></DataGrid.Columns></DataGrid><Button Margin="0,8,0,0" HorizontalAlignment="Left" Content="Принудительно снять блокировку" Command="{Binding ForceUnlockCommand}" IsEnabled="{Binding CanManageSelectedLock}"/></StackPanel></Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Персонажи" Tag="Персонажи">
                        <Grid Margin="8" IsEnabled="{Binding ArePrivilegedSectionsEnabled}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="320"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Каталог персонажей" Style="{StaticResource SectionTitleTextStyle}"/>
                                    <TextBox Margin="0,8,0,6" Text="{Binding CharactersSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Поиск по имени, id, расе"/>
                                    <DataGrid ItemsSource="{Binding FilteredCharacters}" SelectedValuePath="Id" SelectedValue="{Binding SelectedCharacterId, UpdateSourceTrigger=PropertyChanged}" MinHeight="420">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="1.8*"/>
                                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="1.3*"/>
                                            <DataGridTextColumn Header="Описание" Binding="{Binding Extra}" Width="1.8*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <WrapPanel Margin="0,8,0,0"><Button Content="Открыть" Command="{Binding OpenCharacterCommand}" IsEnabled="{Binding CanManageSelectedCharacter}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding RefreshSelectedCharacterCommand}" IsEnabled="{Binding CanOpenSelectedCharacter}"/></WrapPanel>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Column="1" Margin="8,0,0,0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Редактор персонажа" Style="{StaticResource SectionTitleTextStyle}"/><TextBlock Text="{Binding SelectedCharacterSummary}" Margin="0,6,0,0"/></StackPanel></Border>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource SubtleCardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Основная информация" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="Имя" Margin="0,6,0,0"/><TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Раса" Margin="0,6,0,0"/><TextBox Text="{Binding EditRace, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Рост / Возраст" Margin="0,6,0,0"/><WrapPanel><TextBox Width="140" Text="{Binding EditHeight, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="100" Text="{Binding EditAge, UpdateSourceTrigger=PropertyChanged}"/></WrapPanel><TextBlock Text="Описание" Margin="0,6,0,0"/><TextBox Height="70" TextWrapping="Wrap" Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Предыстория" Margin="0,6,0,0"/><TextBox Height="90" TextWrapping="Wrap" Text="{Binding EditBackstory, UpdateSourceTrigger=PropertyChanged}"/></StackPanel></Border>
                                        <Border Grid.Column="1" Style="{StaticResource SubtleCardStyle}"><StackPanel><TextBlock Text="Видимость и заметки" Style="{StaticResource TitleTextStyle}"/><CheckBox Content="Скрыть описание" IsChecked="{Binding VisHideDescription, UpdateSourceTrigger=PropertyChanged}"/><CheckBox Content="Скрыть предысторию" IsChecked="{Binding VisHideBackstory, UpdateSourceTrigger=PropertyChanged}"/><CheckBox Content="Скрыть характеристики" IsChecked="{Binding VisHideStats, UpdateSourceTrigger=PropertyChanged}"/><CheckBox Content="Скрыть репутацию" IsChecked="{Binding VisHideReputation, UpdateSourceTrigger=PropertyChanged}"/><WrapPanel Margin="0,8,0,0"><Button Content="Загрузить видимость" Command="{Binding VisibilityLoadCommand}" IsEnabled="{Binding CanManageCharacterVisibility}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Сохранить видимость" Command="{Binding VisibilitySaveCommand}" IsEnabled="{Binding CanManageCharacterVisibility}"/></WrapPanel><Separator Margin="0,8,0,8"/><TextBlock Text="Заметки" Style="{StaticResource TitleTextStyle}"/><TextBox Text="{Binding NoteTitle, UpdateSourceTrigger=PropertyChanged}" ToolTip="Заголовок заметки"/><TextBox Height="70" Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding NoteText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Краткое содержание"/><WrapPanel Margin="0,6,0,0"><ComboBox Width="180" SelectedValuePath="Tag" SelectedValue="{Binding NoteVisibility, UpdateSourceTrigger=PropertyChanged}"><ComboBoxItem Content="Личное" Tag="Private"/><ComboBoxItem Content="Для ведущего" Tag="Moderator"/><ComboBoxItem Content="Публичное" Tag="Public"/></ComboBox><Button Content="Создать" Command="{Binding NotesCreateCommand}" IsEnabled="{Binding CanCreateNote}"/></WrapPanel><TextBox Margin="0,6,0,0" Text="{Binding NoteTargetId, UpdateSourceTrigger=PropertyChanged}" ToolTip="Поиск/фильтр по targetId"/></StackPanel></Border>
                                    </Grid>
                                    <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0"><StackPanel><TextBlock Text="Характеристики" Style="{StaticResource SectionTitleTextStyle}"/><UniformGrid Columns="5" Margin="0,6,0,0"><StackPanel><TextBlock Text="Здоровье"/><TextBox Text="{Binding Health}"/></StackPanel><StackPanel><TextBlock Text="Физ. броня"/><TextBox Text="{Binding PhysicalArmor}"/></StackPanel><StackPanel><TextBlock Text="Маг. броня"/><TextBox Text="{Binding MagicalArmor}"/></StackPanel><StackPanel><TextBlock Text="Мораль"/><TextBox Text="{Binding Morale}"/></StackPanel><StackPanel><TextBlock Text="Сила"/><TextBox Text="{Binding Strength}"/></StackPanel><StackPanel><TextBlock Text="Ловкость"/><TextBox Text="{Binding Dexterity}"/></StackPanel><StackPanel><TextBlock Text="Выносливость"/><TextBox Text="{Binding Endurance}"/></StackPanel><StackPanel><TextBlock Text="Мудрость"/><TextBox Text="{Binding Wisdom}"/></StackPanel><StackPanel><TextBlock Text="Интеллект"/><TextBox Text="{Binding Intellect}"/></StackPanel><StackPanel><TextBlock Text="Харизма"/><TextBox Text="{Binding Charisma}"/></StackPanel></UniformGrid><Button Margin="0,8,0,0" HorizontalAlignment="Left" Content="Сохранить характеристики" Command="{Binding SaveStatsCommand}" IsEnabled="{Binding CanManageSelectedCharacter}"/></StackPanel></Border>
                                    <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0"><StackPanel><TextBlock Text="Финансы и опыт" Style="{StaticResource SectionTitleTextStyle}"/><UniformGrid Columns="4" Margin="0,6,0,0"><StackPanel><TextBlock Text="Железо"/><TextBox Text="{Binding Iron}"/></StackPanel><StackPanel><TextBlock Text="Бронза"/><TextBox Text="{Binding Bronze}"/></StackPanel><StackPanel><TextBlock Text="Серебро"/><TextBox Text="{Binding Silver}"/></StackPanel><StackPanel><TextBlock Text="Золото"/><TextBox Text="{Binding Gold}"/></StackPanel></UniformGrid><Button Margin="0,8,0,0" HorizontalAlignment="Left" Content="Сохранить финансы" Command="{Binding SaveMoneyCommand}" IsEnabled="{Binding CanManageSelectedCharacter}"/></StackPanel></Border>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="Инвентарь" Style="{StaticResource SectionTitleTextStyle}"/><ListBox ItemsSource="{Binding InventoryRows}" MinHeight="150"/></StackPanel></Border>
                                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,0,8"><StackPanel><TextBlock Text="Спутники" Style="{StaticResource SectionTitleTextStyle}"/><ListBox ItemsSource="{Binding CompanionRows}" MinHeight="150"/></StackPanel></Border>
                                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Владения" Style="{StaticResource SectionTitleTextStyle}"/><ListBox ItemsSource="{Binding HoldingsRows}" MinHeight="150"/></StackPanel></Border>
                                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Репутация" Style="{StaticResource SectionTitleTextStyle}"/><ListBox ItemsSource="{Binding ReputationRows}" MinHeight="150"/></StackPanel></Border>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Модерация" Tag="Модерация">
                        <Grid Margin="8" IsEnabled="{Binding ArePrivilegedSectionsEnabled}">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Всего игроков" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding PlayersCount}" FontSize="20"/></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Онлайн" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding ActivePlayersCount}" FontSize="20"/></StackPanel></Border>
                                <Border Grid.Column="2" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="В муте/блоке" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding LocksCount}" FontSize="20"/></StackPanel></Border>
                                <Border Grid.Column="3" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Всего бросков" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding DiceFeedRows.Count}" FontSize="20"/></StackPanel></Border>
                                <Border Grid.Column="4" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Ожидают решения" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding PendingRequestsCount}" FontSize="20"/></StackPanel></Border>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="2.4*"/><ColumnDefinition Width="1.8*"/></Grid.ColumnDefinitions>
                                <TabControl>
                                    <TabItem Header="Запросы">
                                        <Grid Margin="6"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                            <DataGrid ItemsSource="{Binding PendingRequests}" SelectedValuePath="Id" SelectedValue="{Binding SelectedPendingRequestId, UpdateSourceTrigger=PropertyChanged}"><DataGrid.Columns><DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="1.4*"/><DataGridTextColumn Header="Тип" Binding="{Binding Name}" Width="1.1*"/><DataGridTextColumn Header="Статус" Binding="{Binding State}" Width="1*"/><DataGridTextColumn Header="Детали" Binding="{Binding Extra}" Width="2*"/></DataGrid.Columns></DataGrid>
                                            <WrapPanel Grid.Row="1" Margin="0,8,0,0"><Button Content="Одобрить" Command="{Binding ApproveRequestCommand}" IsEnabled="{Binding CanModerateSelectedRequest}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Отклонить" Command="{Binding RejectRequestCommand}" IsEnabled="{Binding CanModerateSelectedRequest}"/><TextBox Width="260" Text="{Binding RequestComment, UpdateSourceTrigger=PropertyChanged}" ToolTip="Комментарий модератора"/></WrapPanel>
                                        </Grid>
                                    </TabItem>
                                    <TabItem Header="Лента бросков">
                                        <Border Style="{StaticResource CardStyle}" Margin="6" Padding="8"><ListBox ItemsSource="{Binding DiceFeedRows}"/></Border>
                                    </TabItem>
                                    <TabItem Header="События">
                                        <Border Style="{StaticResource CardStyle}" Margin="6"><StackPanel><TextBlock Text="События модерации" Style="{StaticResource SectionTitleTextStyle}"/><TextBlock Text="Раздел работает в минимальном режиме: используйте заявки и ленту бросков для оперативной работы." TextWrapping="Wrap" Margin="0,6,0,0"/></StackPanel></Border>
                                    </TabItem>
                                </TabControl>
                                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0"><StackPanel><TextBlock Text="Контекст и действия" Style="{StaticResource SectionTitleTextStyle}"/><TextBlock Text="{Binding SelectedRequestSummary}" Margin="0,6,0,0" TextWrapping="Wrap"/><TextBlock Text="{Binding SelectedPlayerSummary}" Margin="0,6,0,0" TextWrapping="Wrap"/><TextBlock Text="{Binding SelectedCharacterSummary}" Margin="0,6,0,0" TextWrapping="Wrap"/><Border Style="{StaticResource SubtleCardStyle}" Margin="0,10,0,0"><StackPanel><TextBlock Text="История заявок" Style="{StaticResource TitleTextStyle}"/><ListBox ItemsSource="{Binding RequestHistoryRows}" MinHeight="220"/></StackPanel></Border></StackPanel></Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Сессия" Tag="Сессия">
                        <Grid Margin="8" IsEnabled="{Binding ArePrivilegedSectionsEnabled}">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Сессия" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding SessionSummary}" TextWrapping="Wrap"/></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Бой" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding CombatTrackerSummary}" TextWrapping="Wrap"/></StackPanel></Border>
                                <Border Grid.Column="2" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Чат" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding ChatSummary}" TextWrapping="Wrap"/></StackPanel></Border>
                                <Border Grid.Column="3" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Аудио" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding AudioSummary}" TextWrapping="Wrap"/></StackPanel></Border>
                            </Grid>
                            <TabControl Grid.Row="1" Margin="0,10,0,0">
                                <TabItem Header="Бой">
                                    <Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="1.3*"/><ColumnDefinition Width="1.8*"/></Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Управление боем" Style="{StaticResource SectionTitleTextStyle}"/><WrapPanel Margin="0,8,0,0"><TextBox Width="150" Text="{Binding CombatSessionId, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Запустить" Command="{Binding CombatStartCommand}" IsEnabled="{Binding CanControlCombat}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Завершить" Command="{Binding CombatEndCommand}" IsEnabled="{Binding CanControlCombat}"/></WrapPanel><WrapPanel Margin="0,8,0,0"><Button Style="{StaticResource GhostButtonStyle}" Content="Следующий ход" Command="{Binding CombatNextTurnCommand}" IsEnabled="{Binding CanControlCombat}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Предыдущий ход" Command="{Binding CombatPrevTurnCommand}" IsEnabled="{Binding CanControlCombat}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Следующий раунд" Command="{Binding CombatNextRoundCommand}" IsEnabled="{Binding CanControlCombat}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Пропустить" Command="{Binding CombatSkipTurnCommand}" IsEnabled="{Binding CanControlCombat}"/></WrapPanel></StackPanel></Border>
                                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Участники" Style="{StaticResource SectionTitleTextStyle}"/><WrapPanel Margin="0,8,0,0"><TextBox Width="130" Text="{Binding NewParticipantName, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="90" Text="{Binding NewParticipantKind, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Добавить" Command="{Binding CombatAddParticipantCommand}" IsEnabled="{Binding CanControlCombat}"/></WrapPanel><WrapPanel Margin="0,8,0,0"><TextBox Width="210" Text="{Binding SelectedCombatParticipantId, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Удалить" Command="{Binding CombatRemoveParticipantCommand}" IsEnabled="{Binding CanManageCombatSelection}"/></WrapPanel><ListBox ItemsSource="{Binding CombatRows}" MinHeight="220" Margin="0,8,0,0"/></StackPanel></Border>
                                        <Border Grid.Column="2" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="История боя" Style="{StaticResource SectionTitleTextStyle}"/><ListBox ItemsSource="{Binding CombatHistoryRows}" MinHeight="320"/></StackPanel></Border>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Чат">
                                    <Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="1.4*"/></Grid.ColumnDefinitions>
                                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                            <WrapPanel><TextBox Width="140" Text="{Binding ChatSessionId, UpdateSourceTrigger=PropertyChanged}"/><ComboBox Width="170" ItemsSource="{Binding ChatMessageTypeOptions}" SelectedItem="{Binding ChatMessageType, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding ChatRefreshCommand}" IsEnabled="{Binding IsIdle}"/></WrapPanel>
                                            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,8"><ListBox ItemsSource="{Binding ChatMessageRows}"/></Border>
                                            <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBox Margin="0,0,8,0" Text="{Binding ChatMessageText, UpdateSourceTrigger=PropertyChanged}"/><Button Grid.Column="1" Content="Отправить" Command="{Binding ChatSendCommand}" IsEnabled="{Binding CanSendChat}"/></Grid>
                                        </Grid>
                                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0"><StackPanel><TextBlock Text="Модерация чата" Style="{StaticResource SectionTitleTextStyle}"/><ComboBox Margin="0,8,0,0" SelectedValuePath="Tag" SelectedValue="{Binding ChatModerationUserId, UpdateSourceTrigger=PropertyChanged}"><ComboBoxItem Content="Выбрать пользователя" Tag=""/><ComboBoxItem Content="По ID вручную" Tag="manual"/></ComboBox><TextBox Text="{Binding ChatModerationReason, UpdateSourceTrigger=PropertyChanged}" ToolTip="Причина" Margin="0,6,0,0"/><WrapPanel Margin="0,6,0,0"><Button Style="{StaticResource GhostButtonStyle}" Content="Мут" Command="{Binding ChatMuteUserCommand}" IsEnabled="{Binding CanModerateChatUser}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Снять мут" Command="{Binding ChatUnmuteUserCommand}" IsEnabled="{Binding CanModerateChatUser}"/></WrapPanel><WrapPanel Margin="0,6,0,0"><TextBox Width="58" Text="{Binding ChatSlowPublicSeconds}"/><TextBox Width="58" Text="{Binding ChatSlowHiddenSeconds}"/><TextBox Width="58" Text="{Binding ChatSlowAdminOnlySeconds}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Slow mode" Command="{Binding ChatSetSlowModeCommand}" IsEnabled="{Binding CanManageChatControls}"/></WrapPanel><ListBox Margin="0,8,0,0" ItemsSource="{Binding ChatRestrictionRows}" MinHeight="180"/></StackPanel></Border>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Аудио">
                                    <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <Border Style="{StaticResource CardStyle}"><StackPanel><WrapPanel><TextBox Width="140" Text="{Binding AudioSessionId, UpdateSourceTrigger=PropertyChanged}"/><ComboBox Width="160" Text="{Binding AudioModeInput, UpdateSourceTrigger=PropertyChanged}" IsEditable="True"><ComboBoxItem Content="ambient"/><ComboBoxItem Content="combat"/><ComboBoxItem Content="dialog"/></ComboBox><TextBox Width="160" Text="{Binding AudioCategoryInput, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding AudioRefreshCommand}" IsEnabled="{Binding IsIdle}"/><Button Content="Применить" Command="{Binding AudioSetModeCommand}" IsEnabled="{Binding CanControlAudio}"/></WrapPanel><WrapPanel Margin="0,8,0,0"><TextBox Width="220" Text="{Binding AudioSelectedTrackId, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Выбрать трек" Command="{Binding AudioSelectTrackCommand}" IsEnabled="{Binding CanControlAudio}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Следующий" Command="{Binding AudioNextTrackCommand}" IsEnabled="{Binding CanControlAudio}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Сбросить" Command="{Binding AudioClearOverrideCommand}" IsEnabled="{Binding CanControlAudio}"/></WrapPanel></StackPanel></Border>
                                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,0"><StackPanel><DockPanel><TextBlock Text="Библиотека треков" Style="{StaticResource SectionTitleTextStyle}"/><Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="Перезагрузить библиотеку" Command="{Binding AudioReloadLibraryCommand}" IsEnabled="{Binding CanControlAudio}"/></DockPanel><DataGrid ItemsSource="{Binding AudioLibraryRows}" MinHeight="260"/></StackPanel></Border>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Контент" Tag="Контент">
                        <Grid Margin="8" IsEnabled="{Binding ArePrivilegedSectionsEnabled}">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Style="{StaticResource CardStyle}"><DockPanel><TextBlock Text="Классы и навыки" Style="{StaticResource SectionTitleTextStyle}"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Style="{StaticResource GhostButtonStyle}" Content="Обновить классы" Command="{Binding RefreshDefinitionClassesCommand}" IsEnabled="{Binding CanControlContent}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Обновить навыки" Command="{Binding RefreshDefinitionSkillsCommand}" IsEnabled="{Binding CanControlContent}"/></StackPanel></DockPanel></Border>
                            <Grid Grid.Row="1" Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Классы" Style="{StaticResource TitleTextStyle}"/><DataGrid ItemsSource="{Binding ClassDefinitionRows}" SelectedValuePath="Id" SelectedValue="{Binding SelectedClassDefinitionCode, UpdateSourceTrigger=PropertyChanged}" MinHeight="300"/><TextBlock Text="Редактор класса" Style="{StaticResource TitleTextStyle}" Margin="0,8,0,0"/><TextBox Text="{Binding EditClassCode, UpdateSourceTrigger=PropertyChanged}"/><TextBox Height="120" TextWrapping="Wrap" Text="{Binding EditClassDescription, UpdateSourceTrigger=PropertyChanged}"/><WrapPanel Margin="0,8,0,0"><Button Content="Сохранить" Command="{Binding SaveClassDefinitionCommand}" IsEnabled="{Binding CanManageClassDefinition}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Архивировать" Command="{Binding ArchiveClassDefinitionCommand}" IsEnabled="{Binding CanManageClassDefinition}"/></WrapPanel></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Навыки" Style="{StaticResource TitleTextStyle}"/><DataGrid ItemsSource="{Binding SkillDefinitionRows}" SelectedValuePath="Id" SelectedValue="{Binding SelectedSkillDefinitionCode, UpdateSourceTrigger=PropertyChanged}" MinHeight="300"/><TextBlock Text="Редактор навыка" Style="{StaticResource TitleTextStyle}" Margin="0,8,0,0"/><TextBox Text="{Binding EditSkillCode, UpdateSourceTrigger=PropertyChanged}"/><TextBox Height="120" TextWrapping="Wrap" Text="{Binding EditSkillDescription, UpdateSourceTrigger=PropertyChanged}"/><WrapPanel Margin="0,8,0,0"><Button Content="Сохранить" Command="{Binding SaveSkillDefinitionCommand}" IsEnabled="{Binding CanManageSkillDefinition}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Архивировать" Command="{Binding ArchiveSkillDefinitionCommand}" IsEnabled="{Binding CanManageSkillDefinition}"/></WrapPanel></StackPanel></Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Система" Tag="Система">
                        <Grid Margin="8" IsEnabled="{Binding ArePrivilegedSectionsEnabled}">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Резервные копии" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding BackupSummary}" TextWrapping="Wrap"/></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Диагностика" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding DiagnosticsSummary}" TextWrapping="Wrap"/></StackPanel></Border>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><DockPanel><TextBlock Text="Управление backup" Style="{StaticResource SectionTitleTextStyle}"/><Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding BackupRefreshCommand}" IsEnabled="{Binding CanRefreshSystem}"/></DockPanel><WrapPanel Margin="0,8,0,0"><TextBox Width="220" Text="{Binding BackupLabel, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Создать копию" Command="{Binding BackupCreateCommand}" IsEnabled="{Binding CanRefreshSystem}"/></WrapPanel><WrapPanel Margin="0,8,0,0"><TextBox Width="220" Text="{Binding SelectedBackupId, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Восстановить" Command="{Binding BackupRestoreCommand}" IsEnabled="{Binding CanManageSelectedBackup}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Экспорт" Command="{Binding BackupExportCommand}" IsEnabled="{Binding CanManageSelectedBackup}"/></WrapPanel><DataGrid Margin="0,8,0,0" ItemsSource="{Binding BackupItems}" SelectedValuePath="Id" SelectedValue="{Binding SelectedBackupId, UpdateSourceTrigger=PropertyChanged}" MinHeight="260"><DataGrid.Columns><DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="1.6*"/><DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="1.3*"/><DataGridTextColumn Header="Статус" Binding="{Binding State}" Width="1*"/><DataGridTextColumn Header="Создано" Binding="{Binding Extra}" Width="1.4*"/></DataGrid.Columns></DataGrid></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><DockPanel><TextBlock Text="Диагностика (live feed)" Style="{StaticResource SectionTitleTextStyle}"/><Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding DiagnosticsRefreshCommand}" IsEnabled="{Binding CanRefreshSystem}"/></DockPanel><ListBox Margin="0,8,0,0" ItemsSource="{Binding DiagnosticsItems}" SelectedValuePath="Id" SelectedValue="{Binding SelectedDiagnosticsId, UpdateSourceTrigger=PropertyChanged}"><ListBox.ItemTemplate><DataTemplate><Border Style="{StaticResource SubtleCardStyle}" Margin="0,0,0,6"><StackPanel><TextBlock Text="{Binding Name}" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding State}"/><TextBlock Text="{Binding Extra}" Opacity="0.8" TextWrapping="Wrap"/></StackPanel></Border></DataTemplate></ListBox.ItemTemplate></ListBox><TextBlock Text="{Binding SelectedDiagnosticsSummary}" Margin="0,8,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>

                <Popup IsOpen="{Binding IsConnectionPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=ServerButton}" StaysOpen="False">
                    <Border Style="{StaticResource CardStyle}" Width="420" Padding="12">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Подключение к серверу" Style="{StaticResource SectionTitleTextStyle}"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="✕" Width="34" Padding="0" Command="{Binding OpenConnectionPopupCommand}"/>
                            </DockPanel>
                            <TextBlock Text="Хост" Margin="0,10,0,0"/>
                            <TextBox Text="{Binding ServerHostInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Порт" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding ServerPortInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{Binding ConnectionStatusDetail}" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding LastServerHost, StringFormat=Последний host: {0}}" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding LastServerPort, StringFormat=Последний port: {0}}"/>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Подключиться" Command="{Binding ConnectToServerCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Применить" Command="{Binding ApplyConnectionSettingsCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Сбросить" Command="{Binding ResetConnectionDefaultsCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Последний адрес" Command="{Binding UseSavedConnectionSettingsCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Popup>

                <Popup IsOpen="{Binding IsAuthPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=AuthButton}" StaysOpen="False">
                    <Border Style="{StaticResource CardStyle}" Width="360" Padding="12">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Авторизация" Style="{StaticResource SectionTitleTextStyle}"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="✕" Width="34" Padding="0" Command="{Binding ToggleAuthPopupCommand}"/>
                            </DockPanel>
                            <TextBlock Text="Логин" Margin="0,10,0,0"/>
                            <TextBox Text="{Binding LoginText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Пароль" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding PasswordText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{Binding LoginState}" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding LastErrorMessage}" Foreground="{StaticResource DangerBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasConnectionError}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Content="Войти" Command="{Binding LoginCommand}" Margin="0,12,0,0" HorizontalAlignment="Left" IsEnabled="{Binding CanInitiateConnection}"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Grid>
    </Grid>
</Window>
