                    </TabItem>

                    <TabItem Header="Модерация" Tag="Модерация">
                        <Grid Margin="8" IsEnabled="{Binding ArePrivilegedSectionsEnabled}">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Всего игроков" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding PlayersCount}" FontSize="20"/></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Онлайн" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding ActivePlayersCount}" FontSize="20"/></StackPanel></Border>
                                <Border Grid.Column="2" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="В муте/блоке" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding LocksCount}" FontSize="20"/></StackPanel></Border>
