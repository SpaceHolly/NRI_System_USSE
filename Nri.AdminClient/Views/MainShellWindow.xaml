                                <TextBlock Text="{Binding SectionAccessHint}"/>
                            </Border>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Ожидают" Style="{StaticResource TitleTextStyle}"/>
                                        <TextBlock Text="{Binding PendingAccountsCount}" FontSize="20"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Игроки онлайн" Style="{StaticResource TitleTextStyle}"/>
                                        <TextBlock Text="{Binding ActivePlayersCount}" FontSize="20"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource SummaryMetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Блокировки" Style="{StaticResource TitleTextStyle}"/>
                                        <TextBlock Text="{Binding LocksCount}" FontSize="20"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TabControl Grid.Row="2" IsEnabled="{Binding ArePrivilegedSectionsEnabled}">
                                <TabItem Header="Ожидающие аккаунты">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <DataGrid ItemsSource="{Binding PendingAccounts}" SelectedValuePath="Id" SelectedValue="{Binding SelectedPendingAccountId, UpdateSourceTrigger=PropertyChanged}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Идентификатор" Binding="{Binding Id}" Width="1.8*"/>
                                                <DataGridTextColumn Header="Логин" Binding="{Binding Name}" Width="1.2*"/>
                                                <DataGridTextColumn Header="Статус" Binding="{Binding State}" Width="*"/>
                                                <DataGridTextColumn Header="Создан" Binding="{Binding Extra}" Width="1.4*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Border Grid.Column="1" Style="{StaticResource SubtleCardStyle}">
                                            <StackPanel>
