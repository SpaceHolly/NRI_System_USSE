                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style></TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Обновить" Command="{Binding RefreshCommand}" IsEnabled="{Binding IsIdle}"/>
                    <Button x:Name="ServerButton" Style="{StaticResource GhostButtonStyle}" Content="Подключение" Command="{Binding OpenConnectionPopupCommand}"/>
                    <Button x:Name="AuthButton" Style="{StaticResource GhostButtonStyle}" Content="Вход" Command="{Binding ToggleAuthPopupCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,8,8,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Разделы" Style="{StaticResource SectionTitleTextStyle}" Margin="0,0,0,8"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Обзор" Command="{Binding SelectSectionCommand}" CommandParameter="Обзор"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Люди" Command="{Binding SelectSectionCommand}" CommandParameter="Люди"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Персонажи" Command="{Binding SelectSectionCommand}" CommandParameter="Персонажи"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Модерация" Command="{Binding SelectSectionCommand}" CommandParameter="Модерация"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Сессия" Command="{Binding SelectSectionCommand}" CommandParameter="Сессия"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Контент" Command="{Binding SelectSectionCommand}" CommandParameter="Контент"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Система" Command="{Binding SelectSectionCommand}" CommandParameter="Система"/>
                        <Border Style="{StaticResource SubtleCardStyle}" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Панели" Style="{StaticResource TitleTextStyle}"/>
                                <TextBlock Text="{Binding WorkspaceSummary}" Margin="0,4,0,4"/>
                                <TextBlock Text="{Binding SystemActionSummary}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <ItemsControl ItemsSource="{Binding WorkspacePanels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SubtleCardStyle}" Padding="8" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" Style="{StaticResource TitleTextStyle}"/>
                                                            <TextBlock Text="{Binding PanelState}"/>
                                                        </StackPanel>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding StateBadge}" FontSize="18" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <WrapPanel Margin="0,6,0,0">
                                                        <Button Style="{StaticResource GhostButtonStyle}" CommandParameter="{Binding PanelId}" IsEnabled="{Binding DataContext.CanManageWorkspace, RelativeSource={RelativeSource AncestorType=Window}}">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                                    <Setter Property="Content" Value="Открыть отдельно"/>
                                                                    <Setter Property="Command" Value="{Binding DataContext.DetachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDetached}" Value="True">
                                                                            <Setter Property="Content" Value="Вернуть в окно"/>
                                                                            <Setter Property="Command" Value="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SubtleCardStyle}" Margin="0,10,0,0">
