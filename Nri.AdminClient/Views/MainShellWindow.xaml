<Window x:Class="Nri.AdminClient.Views.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Nri.AdminClient.ViewModels"
        Title="NRI / Admin"
        Height="920"
        Width="1540"
        MinHeight="760"
        MinWidth="1240">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <DataTemplate x:Key="CharacterEditorTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="8"><DockPanel Margin="0,0,0,8"><TextBlock Text="Редактор персонажа" FontWeight="Bold" FontSize="18"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="CharacterEditor"/><Button Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="CharacterEditor"/></StackPanel></DockPanel><StackPanel Orientation="Horizontal" Margin="0,0,0,8"><TextBox Width="280" Text="{Binding DataContext.SelectedCharacterId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/><Button Content="Открыть" Command="{Binding DataContext.OpenCharacterCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,8,0"/><Button Content="Lock" Command="{Binding DataContext.AcquireLockCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,8,0"/><Button Content="Release" Command="{Binding DataContext.ReleaseLockCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,8,0"/><Button Content="Force unlock" Command="{Binding DataContext.ForceUnlockCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel><TextBlock Text="{Binding DataContext.LockStateText, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,0,8"/><TextBlock Text="Basic info" FontWeight="Bold"/><WrapPanel><TextBox Width="180" Margin="0,0,4,4" Text="{Binding DataContext.EditName, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="160" Margin="0,0,4,4" Text="{Binding DataContext.EditRace, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="120" Margin="0,0,4,4" Text="{Binding DataContext.EditHeight, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="80" Margin="0,0,4,4" Text="{Binding DataContext.EditAge, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/></WrapPanel><TextBox Height="70" TextWrapping="Wrap" Text="{Binding DataContext.EditDescription, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Height="90" TextWrapping="Wrap" Text="{Binding DataContext.EditBackstory, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,4"/><Button Content="Сохранить basic" Command="{Binding DataContext.SaveBasicInfoCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,0,8"/><TextBlock Text="Stats" FontWeight="Bold"/><WrapPanel><TextBox Width="70" Text="{Binding DataContext.Health, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.PhysicalArmor, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.MagicalArmor, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.Morale, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.Strength, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.Dexterity, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.Endurance, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.Wisdom, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.Intellect, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.Charisma, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/></WrapPanel><Button Content="Сохранить stats" Command="{Binding DataContext.SaveStatsCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,0,8"/><TextBlock Text="Money" FontWeight="Bold"/><WrapPanel><TextBox Width="70" Text="{Binding DataContext.Iron, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.Bronze, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.Silver, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/><TextBox Width="70" Text="{Binding DataContext.Gold, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,4"/></WrapPanel><Button Content="Сохранить money" Command="{Binding DataContext.SaveMoneyCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,0,8"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Grid.Column="0" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}"><StackPanel><TextBlock Text="Inventory" FontWeight="Bold"/><ItemsControl ItemsSource="{Binding DataContext.InventoryRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}"><StackPanel><TextBlock Text="Companions" FontWeight="Bold"/><ItemsControl ItemsSource="{Binding DataContext.CompanionRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Border><Border Grid.Column="2" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}"><StackPanel><TextBlock Text="Holdings" FontWeight="Bold"/><ItemsControl ItemsSource="{Binding DataContext.HoldingsRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Border><Border Grid.Column="3" Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}"><StackPanel><TextBlock Text="Reputation" FontWeight="Bold"/><ItemsControl ItemsSource="{Binding DataContext.ReputationRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Border></Grid></StackPanel></ScrollViewer>
        </DataTemplate>

        <DataTemplate x:Key="RequestsTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}">
            <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><DockPanel Margin="0,0,0,8"><TextBlock Text="Pending requests" FontWeight="Bold" FontSize="18"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Requests"/><Button Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Requests"/></StackPanel></DockPanel><Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions><DataGrid ItemsSource="{Binding DataContext.PendingRequests, RelativeSource={RelativeSource AncestorType=Window}}" SelectedValuePath="Id" SelectedValue="{Binding DataContext.SelectedPendingRequestId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"><DataGrid.Columns><DataGridTextColumn Header="RequestId" Binding="{Binding Id}"/><DataGridTextColumn Header="Type" Binding="{Binding Name}"/><DataGridTextColumn Header="Status" Binding="{Binding State}"/><DataGridTextColumn Header="Details" Binding="{Binding Extra}"/></DataGrid.Columns></DataGrid><StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="Комментарий админа" FontWeight="Bold"/><TextBox Height="80" TextWrapping="Wrap" Text="{Binding DataContext.RequestComment, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><WrapPanel Margin="0,8,0,8"><Button Content="Approve" Command="{Binding DataContext.ApproveRequestCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,8,0"/><Button Content="Reject" Command="{Binding DataContext.RejectRequestCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><TextBlock Text="История заявок" FontWeight="Bold"/><ItemsControl ItemsSource="{Binding DataContext.RequestHistoryRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Grid></Grid>
        </DataTemplate>

        <DataTemplate x:Key="DiceFeedTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}"><StackPanel Margin="8"><DockPanel Margin="0,0,0,8"><TextBlock Text="Dice feed" FontWeight="Bold" FontSize="18"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="DiceFeed"/><Button Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="DiceFeed"/></StackPanel></DockPanel><ItemsControl ItemsSource="{Binding DataContext.DiceFeedRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></DataTemplate>

        <DataTemplate x:Key="CombatTrackerTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}"><Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><DockPanel Margin="0,0,0,8"><TextBlock Text="Combat tracker" FontWeight="Bold" FontSize="18"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="CombatTracker"/><Button Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="CombatTracker"/></StackPanel></DockPanel><Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions><StackPanel Margin="8"><WrapPanel Margin="0,0,0,8"><TextBlock Text="SessionId" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBox Width="160" Text="{Binding DataContext.CombatSessionId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/><Button Content="Start" Command="{Binding DataContext.CombatStartCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,0"/><Button Content="End" Command="{Binding DataContext.CombatEndCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,0"/><Button Content="Refresh" Command="{Binding DataContext.CombatRefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><WrapPanel Margin="0,0,0,8"><Button Content="NextTurn" Command="{Binding DataContext.CombatNextTurnCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,0"/><Button Content="PrevTurn" Command="{Binding DataContext.CombatPrevTurnCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,0"/><Button Content="NextRound" Command="{Binding DataContext.CombatNextRoundCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,0"/><Button Content="SkipTurn" Command="{Binding DataContext.CombatSkipTurnCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><WrapPanel Margin="0,0,0,8"><TextBox Width="160" Text="{Binding DataContext.NewParticipantName, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/><TextBox Width="100" Text="{Binding DataContext.NewParticipantKind, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/><Button Content="AddParticipant" Command="{Binding DataContext.CombatAddParticipantCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><WrapPanel Margin="0,0,0,8"><TextBox Width="220" Text="{Binding DataContext.SelectedCombatParticipantId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/><Button Content="Remove" Command="{Binding DataContext.CombatRemoveParticipantCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,4,0"/><Button Content="DetachCompanion" Command="{Binding DataContext.CombatDetachCompanionCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><ItemsControl ItemsSource="{Binding DataContext.CombatRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel><Border Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="История боя" FontWeight="Bold"/><ItemsControl ItemsSource="{Binding DataContext.CombatHistoryRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Border></Grid></Grid></DataTemplate>

        <DataTemplate x:Key="NotesManagementTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}"><Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><DockPanel Margin="0,0,0,8"><TextBlock Text="Notes management" FontWeight="Bold" FontSize="18"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="NotesManagement"/><Button Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="NotesManagement"/></StackPanel></DockPanel><Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions><StackPanel Margin="8"><WrapPanel Margin="0,0,0,6"><TextBox Width="120" Text="{Binding DataContext.NoteSessionId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/><TextBox Width="120" Text="{Binding DataContext.NoteTargetType, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/><TextBox Width="180" Text="{Binding DataContext.NoteTargetId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Refresh" Command="{Binding DataContext.NotesRefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="6,0,0,0"/></WrapPanel><TextBox Text="{Binding DataContext.NoteTitle, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/><TextBox Text="{Binding DataContext.NoteText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Height="80" TextWrapping="Wrap" Margin="0,0,0,6"/><WrapPanel><TextBox Width="140" Text="{Binding DataContext.NoteVisibility, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/><Button Content="Create" Command="{Binding DataContext.NotesCreateCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><WrapPanel Margin="0,6,0,0"><TextBox Width="220" Text="{Binding DataContext.SelectedNoteId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/><Button Content="Archive" Command="{Binding DataContext.NotesArchiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel></StackPanel><ListBox Grid.Column="1" ItemsSource="{Binding DataContext.NotesRows, RelativeSource={RelativeSource AncestorType=Window}}" Margin="8"/></Grid></Grid></DataTemplate>

        <DataTemplate x:Key="SessionChatTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}"><Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><DockPanel Margin="0,0,0,8"><TextBlock Text="Session chat" FontWeight="Bold" FontSize="18"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="SessionChat"/><Button Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="SessionChat"/></StackPanel></DockPanel><ListBox Grid.Row="1" ItemsSource="{Binding DataContext.ChatRows, RelativeSource={RelativeSource AncestorType=Window}}"/><Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><WrapPanel><TextBox Width="160" Text="{Binding DataContext.ChatSessionId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="120" Text="{Binding DataContext.ChatMessageType, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Refresh" Command="{Binding DataContext.ChatRefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><TextBox Text="{Binding DataContext.ChatMessageText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Отправить" Command="{Binding DataContext.ChatSendCommand, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left"/><TextBlock Text="{Binding DataContext.ChatUnreadText, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel><StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="Модерация" FontWeight="Bold"/><TextBox Text="{Binding DataContext.ChatModerationUserId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Text="{Binding DataContext.ChatModerationReason, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><WrapPanel><Button Content="Mute" Command="{Binding DataContext.ChatMuteUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Content="Unmute" Command="{Binding DataContext.ChatUnmuteUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><WrapPanel><Button Content="Lock players" Command="{Binding DataContext.ChatLockPlayersCommand, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Content="Unlock players" Command="{Binding DataContext.ChatUnlockPlayersCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><WrapPanel><TextBox Width="60" Text="{Binding DataContext.ChatSlowPublicSeconds, RelativeSource={RelativeSource AncestorType=Window}}"/><TextBox Width="60" Text="{Binding DataContext.ChatSlowHiddenSeconds, RelativeSource={RelativeSource AncestorType=Window}}"/><TextBox Width="60" Text="{Binding DataContext.ChatSlowAdminOnlySeconds, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Content="Slow mode" Command="{Binding DataContext.ChatSetSlowModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><ListBox ItemsSource="{Binding DataContext.ChatRestrictionRows, RelativeSource={RelativeSource AncestorType=Window}}" Height="140"/></StackPanel></Grid></Grid></DataTemplate>

        <DataTemplate x:Key="SessionAudioTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}"><Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><DockPanel Margin="0,0,0,8"><TextBlock Text="Session audio" FontWeight="Bold" FontSize="18"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="SessionAudio"/><Button Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="SessionAudio"/></StackPanel></DockPanel><Border Grid.Row="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="{Binding DataContext.AudioStateText, RelativeSource={RelativeSource AncestorType=Window}}"/><WrapPanel><TextBox Width="140" Text="{Binding DataContext.AudioSessionId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="120" Text="{Binding DataContext.AudioModeInput, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="120" Text="{Binding DataContext.AudioCategoryInput, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Refresh" Command="{Binding DataContext.AudioRefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Content="Set mode" Command="{Binding DataContext.AudioSetModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Content="Next" Command="{Binding DataContext.AudioNextTrackCommand, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Content="Clear override" Command="{Binding DataContext.AudioClearOverrideCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><WrapPanel><TextBox Width="220" Text="{Binding DataContext.AudioSelectedTrackId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Select track" Command="{Binding DataContext.AudioSelectTrackCommand, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Content="Reload library" Command="{Binding DataContext.AudioReloadLibraryCommand, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel></StackPanel></Border><ListBox Grid.Row="2" ItemsSource="{Binding DataContext.AudioLibraryRows, RelativeSource={RelativeSource AncestorType=Window}}"/></Grid></DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource CardStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions><StackPanel><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="NRI / Admin" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,12,0"/><Border Style="{StaticResource StatusBadgeStyle}"><TextBlock Text="{Binding ConnectionState}" Foreground="White" FontWeight="SemiBold"/></Border></StackPanel><TextBlock Text="{Binding ConnectionStatusDetail}" Margin="0,6,0,0"/><TextBlock Text="{Binding SessionSummary}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/></StackPanel><WrapPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"><Border Style="{StaticResource CardStyle}" Padding="10,6"><TextBlock Text="{Binding CurrentEndpoint, StringFormat=Endpoint: {0}}"/></Border><Button Content="Обновить" Command="{Binding RefreshCommand}"/><Button Content="Сервер" Command="{Binding OpenConnectionPopupCommand}"/></WrapPanel><StackPanel Grid.Column="2"><WrapPanel HorizontalAlignment="Right"><TextBlock Text="Логин" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBox Width="130" Text="{Binding LoginText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/><TextBlock Text="Пароль" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBox Width="130" Text="{Binding PasswordText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/><Button Content="Войти" Command="{Binding LoginCommand}"/></WrapPanel><TextBlock Text="{Binding LoginSummary, StringFormat=Пользователь: {0}}" HorizontalAlignment="Right" Margin="0,6,0,0"/></StackPanel></Grid></Border>

        <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,8,8,0"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel><TextBlock Text="Разделы" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/><Button Style="{StaticResource SectionNavButtonStyle}" Content="Обзор" Command="{Binding SelectSectionCommand}" CommandParameter="Обзор"/><Button Style="{StaticResource SectionNavButtonStyle}" Content="Люди" Command="{Binding SelectSectionCommand}" CommandParameter="Люди"/><Button Style="{StaticResource SectionNavButtonStyle}" Content="Персонажи" Command="{Binding SelectSectionCommand}" CommandParameter="Персонажи"/><Button Style="{StaticResource SectionNavButtonStyle}" Content="Модерация" Command="{Binding SelectSectionCommand}" CommandParameter="Модерация"/><Button Style="{StaticResource SectionNavButtonStyle}" Content="Сессия" Command="{Binding SelectSectionCommand}" CommandParameter="Сессия"/><Button Style="{StaticResource SectionNavButtonStyle}" Content="Контент" Command="{Binding SelectSectionCommand}" CommandParameter="Контент"/><Button Style="{StaticResource SectionNavButtonStyle}" Content="Система" Command="{Binding SelectSectionCommand}" CommandParameter="Система"/><Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}" Margin="0,10,0,0"><StackPanel><TextBlock Text="Панели" FontWeight="Bold"/><ItemsControl ItemsSource="{Binding WorkspacePanels}"><ItemsControl.ItemTemplate><DataTemplate><DockPanel Margin="0,4,0,4"><TextBlock Text="{Binding Title}" VerticalAlignment="Center"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="👁" Width="34" Padding="0" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding PanelId}"/><Button Content="⇱" Width="34" Padding="0" Command="{Binding DataContext.DetachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding PanelId}"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CanDetach}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Button.Style></Button></StackPanel></DockPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border></StackPanel></ScrollViewer></Border>

            <Grid Grid.Column="1" Margin="0,8,0,0">
                <TabControl SelectedValue="{Binding SelectedSection}" SelectedValuePath="Tag">
                    <TabItem Header="Обзор" Tag="Обзор"><ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Grid.Column="0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Сервер и сессия" FontWeight="Bold" FontSize="16"/><TextBlock Text="{Binding ConnectionState}" Foreground="White" FontWeight="SemiBold" Margin="0,8,0,0"/><TextBlock Text="{Binding CurrentEndpoint}"/><TextBlock Text="{Binding LoginSummary, StringFormat=Вошёл: {0}}"/></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Ключевые метрики" FontWeight="Bold" FontSize="16"/><TextBlock Text="{Binding PendingAccountsCount, StringFormat=Pending accounts: {0}}" Margin="0,8,0,0"/><TextBlock Text="{Binding PlayersCount, StringFormat=Players: {0}}"/><TextBlock Text="{Binding CharactersCount, StringFormat=Characters: {0}}"/><TextBlock Text="{Binding PendingRequestsCount, StringFormat=Pending requests: {0}}"/></StackPanel></Border><Border Grid.Column="2" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Сессия" FontWeight="Bold" FontSize="16"/><TextBlock Text="{Binding HasActiveCombat, StringFormat=Активный бой: {0}}" Margin="0,8,0,0"/><TextBlock Text="{Binding ChatSummary}"/><TextBlock Text="{Binding AudioSummary}"/><TextBlock Text="{Binding DiagnosticsSummary}"/></StackPanel></Border></Grid><Border Grid.Row="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Сводка подключения" FontWeight="Bold" FontSize="16"/><TextBlock Text="{Binding ConnectionStatusDetail}" Margin="0,8,0,0"/><TextBlock Text="{Binding SessionSummary}" Foreground="{StaticResource MutedBrush}"/></StackPanel></Border><Border Grid.Row="2" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Быстрые действия" FontWeight="Bold" FontSize="16"/><WrapPanel Margin="0,8,0,0"><Button Content="Обновить всё" Command="{Binding RefreshCommand}"/><Button Content="Открыть сервер" Command="{Binding OpenConnectionPopupCommand}"/><Button Content="Заявки" Command="{Binding SelectSectionCommand}" CommandParameter="Модерация"/><Button Content="Бой" Command="{Binding SelectSectionCommand}" CommandParameter="Сессия"/><Button Content="Персонажи" Command="{Binding SelectSectionCommand}" CommandParameter="Персонажи"/></WrapPanel></StackPanel></Border></Grid></ScrollViewer></TabItem>
                    <TabItem Header="Люди" Tag="Люди"><TabControl Margin="8"><TabItem Header="Pending accounts"><Grid><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><DataGrid ItemsSource="{Binding PendingAccounts}" SelectedValuePath="Id" SelectedValue="{Binding SelectedPendingAccountId, UpdateSourceTrigger=PropertyChanged}"><DataGrid.Columns><DataGridTextColumn Header="AccountId" Binding="{Binding Id}"/><DataGridTextColumn Header="Login" Binding="{Binding Name}"/><DataGridTextColumn Header="Status" Binding="{Binding State}"/><DataGridTextColumn Header="Created" Binding="{Binding Extra}"/></DataGrid.Columns></DataGrid><StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,8,0,0"><Button Content="Подтвердить" Command="{Binding ApproveCommand}" Margin="0,0,8,0"/><Button Content="Архивировать" Command="{Binding ArchiveCommand}"/></StackPanel></Grid></TabItem><TabItem Header="Players"><DataGrid ItemsSource="{Binding Players}" SelectedValuePath="Id" SelectedValue="{Binding SelectedOwnerUserId, UpdateSourceTrigger=PropertyChanged}"><DataGrid.Columns><DataGridTextColumn Header="UserId" Binding="{Binding Id}"/><DataGridTextColumn Header="Login" Binding="{Binding Name}"/><DataGridTextColumn Header="Status" Binding="{Binding State}"/><DataGridTextColumn Header="Presence" Binding="{Binding Extra}"/></DataGrid.Columns></DataGrid></TabItem><TabItem Header="Locks"><Border Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Locks summary" FontWeight="Bold"/><TextBlock Text="Используйте editor lock / release для текущего персонажа." Margin="0,6,0,0"/><ItemsControl ItemsSource="{Binding DiagnosticsRows}"/></StackPanel></Border></TabItem></TabControl></TabItem>
                    <TabItem Header="Персонажи" Tag="Персонажи"><TabControl Margin="8"><TabItem Header="Characters list"><DockPanel><StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8"><TextBlock Text="OwnerUserId" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBox Width="250" Text="{Binding SelectedOwnerUserId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/><Button Content="Загрузить" Command="{Binding LoadOwnerCharactersCommand}"/></StackPanel><DataGrid ItemsSource="{Binding Characters}" SelectedValuePath="Id" SelectedValue="{Binding SelectedCharacterId, UpdateSourceTrigger=PropertyChanged}"><DataGrid.Columns><DataGridTextColumn Header="CharacterId" Binding="{Binding Id}"/><DataGridTextColumn Header="Name" Binding="{Binding Name}"/><DataGridTextColumn Header="Archived" Binding="{Binding State}"/><DataGridTextColumn Header="Race" Binding="{Binding Extra}"/></DataGrid.Columns></DataGrid></DockPanel></TabItem><TabItem Header="Character editor"><ContentControl Content="{Binding CharacterEditorPanel}" ContentTemplate="{StaticResource CharacterEditorTemplate}"><ContentControl.Style><Style TargetType="ContentControl"><Style.Triggers><DataTrigger Binding="{Binding CharacterEditorPanel.IsVisible}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger><DataTrigger Binding="{Binding CharacterEditorPanel.IsDetached}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></ContentControl.Style></ContentControl></TabItem><TabItem Header="Visibility"><StackPanel Margin="8"><WrapPanel Margin="0,0,0,8"><TextBox Width="220" Text="{Binding SelectedCharacterId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/><Button Content="Load" Command="{Binding VisibilityLoadCommand}" Margin="0,0,6,0"/><Button Content="Save" Command="{Binding VisibilitySaveCommand}"/></WrapPanel><CheckBox Content="Hide description" IsChecked="{Binding VisHideDescription, UpdateSourceTrigger=PropertyChan