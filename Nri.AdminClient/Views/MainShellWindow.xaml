                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Обновить блокировки" Command="{Binding RefreshPeopleSectionCommand}" IsEnabled="{Binding IsIdle}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Персонажи" Tag="Персонажи">
