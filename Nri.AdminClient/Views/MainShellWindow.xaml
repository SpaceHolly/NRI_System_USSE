                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="К разделу персонажей" Command="{Binding SelectSectionCommand}" CommandParameter="Персонажи" IsEnabled="{Binding CanOpenSelectedCharacter}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Блокировки">
