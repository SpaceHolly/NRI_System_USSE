                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Люди" Style="{StaticResource TitleTextStyle}"/>
