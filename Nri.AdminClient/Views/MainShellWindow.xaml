                                                <WrapPanel>
                                                    <TextBox Width="120" Text="{Binding ReferenceWorldId, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBox Width="120" Text="{Binding ReferenceType, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding ReferenceRefreshCommand}" IsEnabled="{Binding CanControlContent}"/>
                                                </WrapPanel>
                                                <TextBox Text="{Binding ReferenceId, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0"/>
                                                <TextBox Text="{Binding ReferenceKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0"/>
                                                <TextBox Text="{Binding ReferenceDisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0"/>
                                                <TextBox Text="{Binding ReferenceDataJson, UpdateSourceTrigger=PropertyChanged}" Height="80" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                <WrapPanel Margin="0,8,0,0">
                                                    <Button Content="Создать" Command="{Binding ReferenceCreateCommand}" IsEnabled="{Binding CanControlContent}"/>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding ReferenceUpdateCommand}" IsEnabled="{Binding CanManageReferenceRecord}"/>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Архивировать" Command="{Binding ReferenceArchiveCommand}" IsEnabled="{Binding CanManageReferenceRecord}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SubtleCardStyle}" Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Записи reference data" Style="{StaticResource TitleTextStyle}"/>
                                                <ListBox ItemsSource="{Binding ReferenceItems}" SelectedValuePath="Id" SelectedValue="{Binding ReferenceId, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}"/>
                                                                <TextBlock Text="{Binding State}" Opacity="0.8"/>
                                                                <TextBlock Text="{Binding Extra}" Opacity="0.7"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Система" Tag="Система">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource HintCardStyle}">
                                <TextBlock Text="{Binding SectionAccessHint}"/>
                            </Border>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Состояние системы" Style="{StaticResource TitleTextStyle}"/>
                                        <TextBlock Text="{Binding SystemHealthSummary}" TextWrapping="Wrap"/>
                                        <Button Style="{StaticResource GhostButtonStyle}" Content="Обновить систему" Command="{Binding RefreshSystemSectionCommand}" IsEnabled="{Binding CanRefreshSystem}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Диагностика" Style="{StaticResource TitleTextStyle}"/>
                                        <TextBlock Text="{Binding DiagnosticsStatusSummary}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedDiagnosticsSummary}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        <Button Style="{StaticResource GhostButtonStyle}" Content="К diagnostics" Command="{Binding FocusSystemDiagnosticsCommand}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource SummaryMetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Резервные копии" Style="{StaticResource TitleTextStyle}"/>
                                        <TextBlock Text="{Binding BackupSummary}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedBackupSummary}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        <Button Style="{StaticResource GhostButtonStyle}" Content="К backups" Command="{Binding FocusSystemBackupsCommand}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Style="{StaticResource SummaryMetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Справочные данные" Style="{StaticResource TitleTextStyle}"/>
                                        <TextBlock Text="{Binding ReferenceSummary}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedReferenceSummary}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        <Button Style="{StaticResource GhostButtonStyle}" Content="К reference" Command="{Binding FocusSystemReferenceCommand}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TabControl Grid.Row="2" IsEnabled="{Binding ArePrivilegedSectionsEnabled}" SelectedIndex="{Binding SelectedSystemTabIndex}">
                                <TabItem Header="Справочные данные">
                                    <Grid Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="3*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Системные reference data" Style="{StaticResource SectionTitleTextStyle}"/>
                                                <TextBlock Text="{Binding ReferenceSummary}" Margin="0,6,0,0"/>
                                                <TextBlock Text="{Binding SelectedReferenceSummary}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                                                <WrapPanel>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding ReferenceRefreshCommand}" IsEnabled="{Binding CanRefreshSystem}"/>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="К контенту" Command="{Binding FocusContentReferenceCommand}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SubtleCardStyle}" Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Строки справочника" Style="{StaticResource TitleTextStyle}"/>
                                                <ListBox ItemsSource="{Binding ReferenceItems}" SelectedValuePath="Id" SelectedValue="{Binding ReferenceId, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}"/>
                                                                <TextBlock Text="{Binding State}" Opacity="0.8"/>
                                                                <TextBlock Text="{Binding Extra}" Opacity="0.7"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Резервные копии">
                                    <Grid Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="3*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Управление резервными копиями" Style="{StaticResource SectionTitleTextStyle}"/>
                                                <TextBlock Text="{Binding BackupSummary}" Margin="0,6,0,0"/>
                                                <TextBlock Text="{Binding SelectedBackupSummary}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                                                <WrapPanel>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding BackupRefreshCommand}" IsEnabled="{Binding CanRefreshSystem}"/>
                                                    <TextBox Width="220" Text="{Binding BackupLabel, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <Button Content="Создать копию" Command="{Binding BackupCreateCommand}" IsEnabled="{Binding CanRefreshSystem}"/>
                                                </WrapPanel>
                                                <WrapPanel Margin="0,8,0,0">
                                                    <TextBox Width="220" Text="{Binding SelectedBackupId, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Восстановить" Command="{Binding BackupRestoreCommand}" IsEnabled="{Binding CanManageSelectedBackup}"/>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Экспортировать" Command="{Binding BackupExportCommand}" IsEnabled="{Binding CanManageSelectedBackup}"/>
                                                </WrapPanel>
                                                <TextBlock Text="Если серверная часть не поддерживает дополнительные backup-операции, клиент оставляет только доступные команды refresh/create/restore/export." Margin="0,12,0,0" TextWrapping="Wrap" Opacity="0.75"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SubtleCardStyle}" Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Список копий" Style="{StaticResource TitleTextStyle}"/>
                                                <ListBox ItemsSource="{Binding BackupItems}" SelectedValuePath="Id" SelectedValue="{Binding SelectedBackupId, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}"/>
                                                                <TextBlock Text="{Binding State}" Opacity="0.8"/>
                                                                <TextBlock Text="{Binding Extra}" Opacity="0.7"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Диагностика">
                                    <Grid Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="3*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Диагностика админа" Style="{StaticResource SectionTitleTextStyle}"/>
                                                <TextBlock Text="{Binding DiagnosticsSummary}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding SelectedDiagnosticsSummary}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                                                <WrapPanel>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Обновить диагностику" Command="{Binding DiagnosticsRefreshCommand}" IsEnabled="{Binding CanRefreshSystem}" HorizontalAlignment="Left"/>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="К backup list" Command="{Binding FocusSystemBackupsCommand}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SubtleCardStyle}" Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Строки диагностики" Style="{StaticResource TitleTextStyle}"/>
                                                <ListBox ItemsSource="{Binding DiagnosticsItems}" SelectedValuePath="Id" SelectedValue="{Binding SelectedDiagnosticsId, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}"/>
                                                                <TextBlock Text="{Binding State}" Opacity="0.8"/>
                                                                <TextBlock Text="{Binding Extra}" Opacity="0.7"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </TabItem>
                </TabControl>

                <Popup IsOpen="{Binding IsConnectionPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=ServerButton}" StaysOpen="False">
                    <Border Style="{StaticResource CardStyle}" Width="420" Padding="12">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Подключение к серверу" Style="{StaticResource SectionTitleTextStyle}"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="✕" Width="34" Padding="0" Command="{Binding OpenConnectionPopupCommand}"/>
                            </DockPanel>
                            <TextBlock Text="Хост" Margin="0,10,0,0"/>
                            <TextBox Text="{Binding ServerHostInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Порт" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding ServerPortInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{Binding ConnectionStatusDetail}" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding LastServerHost, StringFormat=Последний host: {0}}" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding LastServerPort, StringFormat=Последний port: {0}}"/>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Подключиться" Command="{Binding ConnectToServerCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Применить" Command="{Binding ApplyConnectionSettingsCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Сбросить" Command="{Binding ResetConnectionDefaultsCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Последний адрес" Command="{Binding UseSavedConnectionSettingsCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Popup>

                <Popup IsOpen="{Binding IsAuthPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=AuthButton}" StaysOpen="False">
                    <Border Style="{StaticResource CardStyle}" Width="360" Padding="12">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Авторизация" Style="{StaticResource SectionTitleTextStyle}"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="✕" Width="34" Padding="0" Command="{Binding ToggleAuthPopupCommand}"/>
                            </DockPanel>
                            <TextBlock Text="Логин" Margin="0,10,0,0"/>
                            <TextBox Text="{Binding LoginText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Пароль" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding PasswordText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{Binding LoginState}" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding LastErrorMessage}" Foreground="{StaticResource DangerBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasConnectionError}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Content="Войти" Command="{Binding LoginCommand}" Margin="0,12,0,0" HorizontalAlignment="Left" IsEnabled="{Binding CanInitiateConnection}"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Grid>
    </Grid>
</Window>
