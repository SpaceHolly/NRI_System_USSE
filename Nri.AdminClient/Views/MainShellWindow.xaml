                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource HintCardStyle}">
                                <TextBlock Text="{Binding SectionAccessHint}"/>
                            </Border>
                            <Grid Grid.Row="1" IsEnabled="{Binding ArePrivilegedSectionsEnabled}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="340"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
