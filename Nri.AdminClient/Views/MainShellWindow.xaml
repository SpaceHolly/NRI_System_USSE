                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Архивировать" Command="{Binding ArchiveCommand}" IsEnabled="{Binding CanManagePendingAccount}"/>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding RefreshPeopleSectionCommand}" IsEnabled="{Binding IsIdle}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
