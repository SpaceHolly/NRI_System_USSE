                            <Button Style="{StaticResource GhostButtonStyle}" Content="Сбросить override" Command="{Binding DataContext.AudioClearOverrideCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </WrapPanel>
                        <WrapPanel>
                            <TextBox Width="220" Text="{Binding DataContext.AudioSelectedTrackId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Выбрать трек" Command="{Binding DataContext.AudioSelectTrackCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Button Style="{StaticResource GhostButtonStyle}" Content="Обновить библиотеку" Command="{Binding DataContext.AudioReloadLibraryCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <ListBox Grid.Row="2" ItemsSource="{Binding DataContext.AudioLibraryRows, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </Grid>
