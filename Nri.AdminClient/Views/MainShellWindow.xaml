                                                    <TextBox Height="92" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding ReputationNotesInput, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <CheckBox Margin="0,8,0,0" Content="Archived" IsChecked="{Binding ReputationIsArchivedInput, UpdateSourceTrigger=PropertyChanged}"/>
