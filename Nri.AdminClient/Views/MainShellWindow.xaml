<Window x:Class="Nri.AdminClient.Views.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NRI Admin" Height="820" Width="1300">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Логин" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox Width="120" Text="{Binding LoginText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
            <TextBlock Text="Пароль" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox Width="120" Text="{Binding PasswordText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
            <Button Content="Войти" Command="{Binding LoginCommand}" Margin="0,0,8,0"/>
            <Button Content="Обновить" Command="{Binding RefreshCommand}" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding ConnectionState}" Foreground="DarkRed" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <TabControl>
            <TabItem Header="Admin dashboard">
                <StackPanel Margin="8">
                    <TextBlock Text="Overview" FontWeight="Bold"/>
                    <TextBlock Text="Используйте вкладки ниже для управления аккаунтами и персонажами."/>
                </StackPanel>
            </TabItem>

            <TabItem Header="PendingAccountsView">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding PendingAccounts}" AutoGenerateColumns="False" SelectedValuePath="Id" SelectedValue="{Binding SelectedPendingAccountId, UpdateSourceTrigger=PropertyChanged}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="AccountId" Binding="{Binding Id}"/>
                            <DataGridTextColumn Header="Login" Binding="{Binding Name}"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding State}"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding Extra}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,8,0,0">
                        <Button Content="Подтвердить" Command="{Binding ApproveCommand}" Margin="0,0,8,0"/>
                        <Button Content="Архивировать" Command="{Binding ArchiveCommand}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="PlayersView">
                <DataGrid ItemsSource="{Binding Players}" AutoGenerateColumns="False" SelectedValuePath="Id" SelectedValue="{Binding SelectedOwnerUserId, UpdateSourceTrigger=PropertyChanged}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="UserId" Binding="{Binding Id}"/>
                        <DataGridTextColumn Header="Login" Binding="{Binding Name}"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding State}"/>
                        <DataGridTextColumn Header="Presence" Binding="{Binding Extra}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="CharactersView">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="OwnerUserId" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Width="250" Text="{Binding SelectedOwnerUserId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <Button Content="Загрузить" Command="{Binding LoadOwnerCharactersCommand}"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Characters}" AutoGenerateColumns="False" SelectedValuePath="Id" SelectedValue="{Binding SelectedCharacterId, UpdateSourceTrigger=PropertyChanged}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CharacterId" Binding="{Binding Id}"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>
                            <DataGridTextColumn Header="Archived" Binding="{Binding State}"/>
                            <DataGridTextColumn Header="Race" Binding="{Binding Extra}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="CharacterEditorView">
                <ScrollViewer>
                    <StackPanel Margin="8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBox Width="280" Text="{Binding SelectedCharacterId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                            <Button Content="Открыть" Command="{Binding OpenCharacterCommand}" Margin="0,0,8,0"/>
                            <Button Content="Lock" Command="{Binding AcquireLockCommand}" Margin="0,0,8,0"/>
                            <Button Content="Release" Command="{Binding ReleaseLockCommand}" Margin="0,0,8,0"/>
                            <Button Content="Force unlock" Command="{Binding ForceUnlockCommand}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LockStateText}" Margin="0,0,0,8"/>

                        <TextBlock Text="BasicInfo" FontWeight="Bold"/>
                        <WrapPanel>
                            <TextBox Width="180" Margin="0,0,4,4" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Width="160" Margin="0,0,4,4" Text="{Binding EditRace, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Width="120" Margin="0,0,4,4" Text="{Binding EditHeight, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Width="80" Margin="0,0,4,4" Text="{Binding EditAge, UpdateSourceTrigger=PropertyChanged}"/>
                        </WrapPanel>
                        <TextBox Height="70" TextWrapping="Wrap" Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Height="90" TextWrapping="Wrap" Text="{Binding EditBackstory, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,4"/>
                        <Button Content="Сохранить basic" Command="{Binding SaveBasicInfoCommand}" Margin="0,0,0,8"/>

                        <TextBlock Text="Stats" FontWeight="Bold"/>
                        <WrapPanel>
                            <TextBox Width="70" Text="{Binding Health}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding PhysicalArmor}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding MagicalArmor}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding Morale}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding Strength}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding Dexterity}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding Endurance}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding Wisdom}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding Intellect}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding Charisma}" Margin="0,0,4,4"/>
                        </WrapPanel>
                        <Button Content="Сохранить stats" Command="{Binding SaveStatsCommand}" Margin="0,0,0,8"/>

                        <TextBlock Text="Money" FontWeight="Bold"/>
                        <WrapPanel>
                            <TextBox Width="70" Text="{Binding Iron}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding Bronze}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding Silver}" Margin="0,0,4,4"/>
                            <TextBox Width="70" Text="{Binding Gold}" Margin="0,0,4,4"/>
                        </WrapPanel>
                        <Button Content="Сохранить money" Command="{Binding SaveMoneyCommand}" Margin="0,0,0,8"/>

                        <TextBlock Text="Inventory" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding InventoryRows}"/>
                        <TextBlock Text="Companions" FontWeight="Bold" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding CompanionRows}"/>
                        <TextBlock Text="Holdings" FontWeight="Bold" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding HoldingsRows}"/>
                        <TextBlock Text="Reputation" FontWeight="Bold" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding ReputationRows}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="LocksStatusView">
                <StackPanel Margin="8">
                    <TextBlock Text="Lock status связан с редактором персонажа (по выбранному CharacterId)."/>
                    <TextBlock Text="{Binding LockStateText}" FontWeight="Bold"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="ClassesView"><TextBlock Margin="8" Text="Классы: рабочий контейнер под будущее дерево/шестиугольник."/></TabItem>
            <TabItem Header="SkillsView"><TextBlock Margin="8" Text="Навыки: контейнер, подробный модуль будет на следующем этапе."/></TabItem>
        </TabControl>
    </DockPanel>
        Title="NRI Admin" Height="600" Width="980">
    <Grid Margin="8">
        <TabControl>
            <TabItem Header="Dashboard"><TextBlock Text="Admin dashboard placeholder" /></TabItem>
            <TabItem Header="Character"><TextBlock Text="Character view placeholder" /></TabItem>
            <TabItem Header="Requests"><TextBlock Text="Requests view placeholder" /></TabItem>
            <TabItem Header="Combat"><TextBlock Text="Combat view placeholder" /></TabItem>
            <TabItem Header="Chat"><TextBlock Text="Chat panel placeholder" /></TabItem>
            <TabItem Header="Audio"><TextBlock Text="Audio panel placeholder" /></TabItem>
        </TabControl>
    </Grid>
</Window>
