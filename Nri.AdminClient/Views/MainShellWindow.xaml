                                    <Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="1.3*"/><ColumnDefinition Width="1.8*"/></Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Управление боем" Style="{StaticResource SectionTitleTextStyle}"/><WrapPanel Margin="0,8,0,0"><TextBox Width="150" Text="{Binding CombatSessionId, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Запустить" Command="{Binding CombatStartCommand}" IsEnabled="{Binding CanControlCombat}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Завершить" Command="{Binding CombatEndCommand}" IsEnabled="{Binding CanControlCombat}"/></WrapPanel><WrapPanel Margin="0,8,0,0"><Button Style="{StaticResource GhostButtonStyle}" Content="Следующий ход" Command="{Binding CombatNextTurnCommand}" IsEnabled="{Binding CanControlCombat}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Предыдущий ход" Command="{Binding CombatPrevTurnCommand}" IsEnabled="{Binding CanControlCombat}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Следующий раунд" Command="{Binding CombatNextRoundCommand}" IsEnabled="{Binding CanControlCombat}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Пропустить" Command="{Binding CombatSkipTurnCommand}" IsEnabled="{Binding CanControlCombat}"/></WrapPanel></StackPanel></Border>
                                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Участники" Style="{StaticResource SectionTitleTextStyle}"/><WrapPanel Margin="0,8,0,0"><TextBox Width="130" Text="{Binding NewParticipantName, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="90" Text="{Binding NewParticipantKind, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Добавить" Command="{Binding CombatAddParticipantCommand}" IsEnabled="{Binding CanControlCombat}"/></WrapPanel><WrapPanel Margin="0,8,0,0"><TextBox Width="210" Text="{Binding SelectedCombatParticipantId, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Удалить" Command="{Binding CombatRemoveParticipantCommand}" IsEnabled="{Binding CanManageCombatSelection}"/></WrapPanel><ListBox ItemsSource="{Binding CombatRows}" MinHeight="220" Margin="0,8,0,0"/></StackPanel></Border>
                                        <Border Grid.Column="2" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="История боя" Style="{StaticResource SectionTitleTextStyle}"/><ListBox ItemsSource="{Binding CombatHistoryRows}" MinHeight="320"/></StackPanel></Border>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Чат">
                                    <Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="1.4*"/></Grid.ColumnDefinitions>
                                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                            <WrapPanel><ComboBox Width="150" SelectedValuePath="Tag" SelectedValue="{Binding ChatSessionId, UpdateSourceTrigger=PropertyChanged}"><ComboBoxItem Content="Канал: Основная" Tag="default"/></ComboBox><ComboBox Width="170" ItemsSource="{Binding ChatMessageTypeOptions}" SelectedItem="{Binding ChatMessageType, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding ChatRefreshCommand}" IsEnabled="{Binding IsIdle}"/></WrapPanel>
                                            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,8">
                                                <ListBox ItemsSource="{Binding MergedSessionFeedRows}">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ChatMessageRowVm}">
                                                            <Border Style="{StaticResource SubtleCardStyle}" Margin="0,0,0,6">
                                                                <StackPanel>
                                                                    <TextBlock TextWrapping="Wrap">
                                                                        <Run Text="{Binding Sender}" FontWeight="SemiBold"/>
                                                                        <Run Text=": "/>
                                                                        <Run Text="{Binding Text}"/>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding Timestamp}" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                            <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBox Margin="0,0,8,0" Text="{Binding ChatMessageText, UpdateSourceTrigger=PropertyChanged}"/><Button Grid.Column="1" Content="Отправить" Command="{Binding ChatSendCommand}" IsEnabled="{Binding CanSendChat}"/></Grid>
                                        </Grid>
                                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Модерация чата" Style="{StaticResource SectionTitleTextStyle}"/>
                                                <TextBlock Text="Пользователь" Margin="0,8,0,2"/>
                                                <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding ChatModerationUserId, UpdateSourceTrigger=PropertyChanged}">
                                                    <ComboBoxItem Content="Выбрать пользователя" Tag=""/>
                                                    <ComboBoxItem Content="Ввести ID вручную" Tag="manual"/>
                                                </ComboBox>
                                                <TextBlock Text="Причина" Margin="0,6,0,2"/>
                                                <TextBox Text="{Binding ChatModerationReason, UpdateSourceTrigger=PropertyChanged}"/>
                                                <WrapPanel Margin="0,8,0,0">
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Мут" Command="{Binding ChatMuteUserCommand}" IsEnabled="{Binding CanModerateChatUser}"/>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Снять мут" Command="{Binding ChatUnmuteUserCommand}" IsEnabled="{Binding CanModerateChatUser}"/>
                                                </WrapPanel>
                                                <TextBlock Text="Медленный режим (сек.)" Margin="0,8,0,2"/>
                                                <WrapPanel>
                                                    <TextBox Width="58" Text="{Binding ChatSlowPublicSeconds}"/>
                                                    <TextBox Width="58" Text="{Binding ChatSlowHiddenSeconds}"/>
                                                    <TextBox Width="58" Text="{Binding ChatSlowAdminOnlySeconds}"/>
                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="Применить медленный режим" Command="{Binding ChatSetSlowModeCommand}" IsEnabled="{Binding CanManageChatControls}"/>
                                                </WrapPanel>
                                                <TextBlock Text="Ограничения" Margin="0,8,0,4"/>
                                                <ListBox ItemsSource="{Binding ChatRestrictionRows}" MinHeight="180"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Аудио">
                                    <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <Border Style="{StaticResource CardStyle}"><StackPanel><WrapPanel><ComboBox Width="150" SelectedValuePath="Tag" SelectedValue="{Binding AudioSessionId, UpdateSourceTrigger=PropertyChanged}"><ComboBoxItem Content="Сессия: Основная" Tag="default"/></ComboBox><ComboBox Width="160" Text="{Binding AudioModeInput, UpdateSourceTrigger=PropertyChanged}" IsEditable="True"><ComboBoxItem Content="ambient"/><ComboBoxItem Content="combat"/><ComboBoxItem Content="dialog"/></ComboBox><TextBox Width="160" Text="{Binding AudioCategoryInput, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding AudioRefreshCommand}" IsEnabled="{Binding IsIdle}"/><Button Content="Применить" Command="{Binding AudioSetModeCommand}" IsEnabled="{Binding CanControlAudio}"/></WrapPanel><WrapPanel Margin="0,8,0,0"><TextBox Width="220" Text="{Binding AudioSelectedTrackId, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Выбрать трек" Command="{Binding AudioSelectTrackCommand}" IsEnabled="{Binding CanControlAudio}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Следующий" Command="{Binding AudioNextTrackCommand}" IsEnabled="{Binding CanControlAudio}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Сбросить" Command="{Binding AudioClearOverrideCommand}" IsEnabled="{Binding CanControlAudio}"/></WrapPanel></StackPanel></Border>
                                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,0"><StackPanel><DockPanel><TextBlock Text="Библиотека треков" Style="{StaticResource SectionTitleTextStyle}"/><Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="Перезагрузить библиотеку" Command="{Binding AudioReloadLibraryCommand}" IsEnabled="{Binding CanControlAudio}"/></DockPanel><DataGrid ItemsSource="{Binding AudioLibraryRows}" MinHeight="260"/></StackPanel></Border>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Контент" Tag="Контент">
                        <Grid Margin="8" IsEnabled="{Binding ArePrivilegedSectionsEnabled}">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Style="{StaticResource CardStyle}"><DockPanel><TextBlock Text="Классы и навыки" Style="{StaticResource SectionTitleTextStyle}"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Style="{StaticResource GhostButtonStyle}" Content="Обновить классы" Command="{Binding RefreshDefinitionClassesCommand}" IsEnabled="{Binding CanControlContent}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Обновить навыки" Command="{Binding RefreshDefinitionSkillsCommand}" IsEnabled="{Binding CanControlContent}"/></StackPanel></DockPanel></Border>
                            <Grid Grid.Row="1" Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Классы" Style="{StaticResource TitleTextStyle}"/><TextBox Margin="0,6,0,6" Text="{Binding ClassSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Поиск по коду, названию, ветке"/><DataGrid ItemsSource="{Binding FilteredClassDefinitionRows}" SelectedValuePath="Id" SelectedValue="{Binding SelectedClassDefinitionCode, UpdateSourceTrigger=PropertyChanged}" MinHeight="250"/><TextBlock Text="Редактор класса" Style="{StaticResource TitleTextStyle}" Margin="0,8,0,0"/><TextBlock Text="Код"/><TextBox Text="{Binding EditClassCode, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Родительский класс" Margin="0,6,0,0"/><TextBox Text="{Binding EditClassParentClassCode, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Корневой класс" Margin="0,6,0,0"/><TextBox Text="{Binding EditClassRootClassCode, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Уровень" Margin="0,6,0,0"/><TextBox Text="{Binding EditClassLevel, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Описание" Margin="0,6,0,0"/><TextBox Height="80" TextWrapping="Wrap" Text="{Binding EditClassDescription, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="{Binding DefinitionHintText}" Margin="0,6,0,0" Opacity="0.8" TextWrapping="Wrap"/><WrapPanel Margin="0,8,0,0"><Button Content="Сохранить" Command="{Binding SaveClassDefinitionCommand}" IsEnabled="{Binding CanManageClassDefinition}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Архивировать" Command="{Binding ArchiveClassDefinitionCommand}" IsEnabled="{Binding CanManageClassDefinition}"/></WrapPanel></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Навыки (справочник)" Style="{StaticResource TitleTextStyle}"/><TextBox Margin="0,6,0,6" Text="{Binding SkillSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Поиск по коду, названию, категории"/><DataGrid ItemsSource="{Binding FilteredSkillDefinitionRows}" SelectedValuePath="Id" SelectedValue="{Binding SelectedSkillDefinitionCode, UpdateSourceTrigger=PropertyChanged}" MinHeight="250"/><TextBlock Text="Редактор навыка" Style="{StaticResource TitleTextStyle}" Margin="0,8,0,0"/><TextBlock Text="Код"/><TextBox Text="{Binding EditSkillCode, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Описание" Margin="0,6,0,0"/><TextBox Height="80" TextWrapping="Wrap" Text="{Binding EditSkillDescription, UpdateSourceTrigger=PropertyChanged}"/><WrapPanel Margin="0,8,0,0"><Button Content="Сохранить" Command="{Binding SaveSkillDefinitionCommand}" IsEnabled="{Binding CanManageSkillDefinition}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Архивировать" Command="{Binding ArchiveSkillDefinitionCommand}" IsEnabled="{Binding CanManageSkillDefinition}"/></WrapPanel></StackPanel></Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Система" Tag="Система">
                        <Grid Margin="8" IsEnabled="{Binding ArePrivilegedSectionsEnabled}">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Резервные копии" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding BackupSummary}" TextWrapping="Wrap"/></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource SummaryMetricCardStyle}"><StackPanel><TextBlock Text="Диагностика" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding DiagnosticsSummary}" TextWrapping="Wrap"/></StackPanel></Border>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><DockPanel><TextBlock Text="Управление резервными копиями" Style="{StaticResource SectionTitleTextStyle}"/><Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding BackupRefreshCommand}" IsEnabled="{Binding CanRefreshSystem}"/></DockPanel><WrapPanel Margin="0,8,0,0"><TextBox Width="220" Text="{Binding BackupLabel, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Создать резервную копию" Command="{Binding BackupCreateCommand}" IsEnabled="{Binding CanRefreshSystem}"/></WrapPanel><WrapPanel Margin="0,8,0,0"><TextBox Width="220" Text="{Binding SelectedBackupId, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Восстановить" Command="{Binding BackupRestoreCommand}" IsEnabled="{Binding CanManageSelectedBackup}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Экспортировать" Command="{Binding BackupExportCommand}" IsEnabled="{Binding CanManageSelectedBackup}"/></WrapPanel><DataGrid Margin="0,8,0,0" ItemsSource="{Binding BackupItems}" SelectedValuePath="Id" SelectedValue="{Binding SelectedBackupId, UpdateSourceTrigger=PropertyChanged}" MinHeight="260"><DataGrid.Columns><DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="1.6*"/><DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="1.3*"/><DataGridTextColumn Header="Статус" Binding="{Binding State}" Width="1*"/><DataGridTextColumn Header="Создано" Binding="{Binding Extra}" Width="1.4*"/></DataGrid.Columns></DataGrid></StackPanel></Border>
                                <Border Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><DockPanel><TextBlock Text="Диагностика (live feed)" Style="{StaticResource SectionTitleTextStyle}"/><Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="Обновить" Command="{Binding DiagnosticsRefreshCommand}" IsEnabled="{Binding CanRefreshSystem}"/></DockPanel><ListBox Margin="0,8,0,0" ItemsSource="{Binding DiagnosticsItems}" SelectedValuePath="Id" SelectedValue="{Binding SelectedDiagnosticsId, UpdateSourceTrigger=PropertyChanged}"><ListBox.ItemTemplate><DataTemplate><Border Style="{StaticResource SubtleCardStyle}" Margin="0,0,0,6"><StackPanel><TextBlock Text="{Binding Name}" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding State}"/><TextBlock Text="{Binding Extra}" Opacity="0.8" TextWrapping="Wrap"/></StackPanel></Border></DataTemplate></ListBox.ItemTemplate></ListBox><TextBlock Text="{Binding SelectedDiagnosticsSummary}" Margin="0,8,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>

                <Popup IsOpen="{Binding IsConnectionPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=ServerButton}" StaysOpen="False">
                    <Border Style="{StaticResource CardStyle}" Width="420" Padding="12">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Подключение к серверу" Style="{StaticResource SectionTitleTextStyle}"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="✕" Width="34" Padding="0" Command="{Binding OpenConnectionPopupCommand}"/>
                            </DockPanel>
                            <TextBlock Text="Хост" Margin="0,10,0,0"/>
                            <TextBox Text="{Binding ServerHostInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Порт" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding ServerPortInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{Binding ConnectionStatusDetail}" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding LastServerHost, StringFormat=Последний host: {0}}" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding LastServerPort, StringFormat=Последний port: {0}}"/>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Подключиться" Command="{Binding ConnectToServerCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Применить" Command="{Binding ApplyConnectionSettingsCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Сбросить" Command="{Binding ResetConnectionDefaultsCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                                <Button Style="{StaticResource GhostButtonStyle}" Content="Последний адрес" Command="{Binding UseSavedConnectionSettingsCommand}" IsEnabled="{Binding CanInitiateConnection}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Popup>

                <Popup IsOpen="{Binding IsAuthPopupOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=AuthButton}" StaysOpen="False">
                    <Border Style="{StaticResource CardStyle}" Width="360" Padding="12">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Авторизация" Style="{StaticResource SectionTitleTextStyle}"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Content="✕" Width="34" Padding="0" Command="{Binding ToggleAuthPopupCommand}"/>
                            </DockPanel>
                            <TextBlock Text="Логин" Margin="0,10,0,0"/>
                            <TextBox Text="{Binding LoginText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Пароль" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding PasswordText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Старый пароль (смена)" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding OldPasswordText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Новый пароль" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding NewPasswordText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{Binding LoginState}" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding LastErrorMessage}" Foreground="{StaticResource DangerBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasConnectionError}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <WrapPanel Margin="0,12,0,0"><Button Content="Войти" Command="{Binding LoginCommand}" HorizontalAlignment="Left" IsEnabled="{Binding CanInitiateConnection}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Сменить пароль" Command="{Binding ChangePasswordCommand}" IsEnabled="{Binding ArePrivilegedSectionsEnabled}"/></WrapPanel>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Grid>
    </Grid>
</Window>
