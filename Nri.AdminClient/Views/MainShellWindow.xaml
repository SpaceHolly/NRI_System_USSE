                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SubtleCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Блокировки / внимание" Style="{StaticResource TitleTextStyle}"/>
