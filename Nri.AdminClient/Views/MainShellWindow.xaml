                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CharacterEditorPanel.IsVisible}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CharacterEditorPanel.IsDetached}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ContentControl.Style>
                                        </ContentControl>
                                    </TabItem>
                                    <TabItem Header="Видимость" Tag="Visibility">
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel Margin="8">
                                                <TextBlock Text="Настройки видимости" Style="{StaticResource SectionTitleTextStyle}"/>
