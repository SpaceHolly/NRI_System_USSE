<Window x:Class="Nri.AdminClient.Views.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Nri.AdminClient.ViewModels"
        Title="NRI / Admin"
        Height="920"
        Width="1540"
        MinHeight="760"
        MinWidth="1240">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="SectionHostTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Border Background="Transparent">
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CharacterEditorTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Редактор персонажа" Style="{StaticResource SectionTitleTextStyle}"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Style="{StaticResource GhostButtonStyle}" Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="CharacterEditor"/>
                            <Button Style="{StaticResource GhostButtonStyle}" Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="CharacterEditor"/>
                        </StackPanel>
                    </DockPanel>
                    <WrapPanel Margin="0,0,0,8">
                        <TextBox Width="280" Text="{Binding DataContext.SelectedCharacterId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Открыть" Command="{Binding DataContext.OpenCharacterCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanManageSelectedCharacter, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Lock" Command="{Binding DataContext.AcquireLockCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanManageSelectedCharacter, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Release" Command="{Binding DataContext.ReleaseLockCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanManageSelectedCharacter, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Force unlock" Command="{Binding DataContext.ForceUnlockCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanManageSelectedLock, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </WrapPanel>
                    <Border Style="{StaticResource SubtleCardStyle}"><TextBlock Text="{Binding DataContext.LockStateText, RelativeSource={RelativeSource AncestorType=Window}}"/></Border>
                    <TextBlock Text="Basic info" Style="{StaticResource SectionTitleTextStyle}" Margin="0,8,0,4"/>
                    <WrapPanel>
                        <TextBox Width="180" Text="{Binding DataContext.EditName, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Width="160" Text="{Binding DataContext.EditRace, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Width="120" Text="{Binding DataContext.EditHeight, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Width="80" Text="{Binding DataContext.EditAge, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                    </WrapPanel>
                    <TextBox Height="70" TextWrapping="Wrap" Text="{Binding DataContext.EditDescription, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox Height="90" TextWrapping="Wrap" Text="{Binding DataContext.EditBackstory, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Сохранить basic" Command="{Binding DataContext.SaveBasicInfoCommand, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left" IsEnabled="{Binding DataContext.CanManageSelectedCharacter, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <TextBlock Text="Stats" Style="{StaticResource SectionTitleTextStyle}" Margin="0,8,0,4"/>
                    <WrapPanel>
                        <TextBox Width="70" Text="{Binding DataContext.Health, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.PhysicalArmor, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.MagicalArmor, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.Morale, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.Strength, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.Dexterity, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.Endurance, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.Wisdom, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.Intellect, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.Charisma, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </WrapPanel>
                    <Button Content="Сохранить stats" Command="{Binding DataContext.SaveStatsCommand, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left" IsEnabled="{Binding DataContext.CanManageSelectedCharacter, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <TextBlock Text="Money" Style="{StaticResource SectionTitleTextStyle}" Margin="0,8,0,4"/>
                    <WrapPanel>
                        <TextBox Width="70" Text="{Binding DataContext.Iron, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.Bronze, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.Silver, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBox Width="70" Text="{Binding DataContext.Gold, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </WrapPanel>
                    <Button Content="Сохранить money" Command="{Binding DataContext.SaveMoneyCommand, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left" IsEnabled="{Binding DataContext.CanManageSelectedCharacter, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource SubtleCardStyle}"><StackPanel><TextBlock Text="Inventory" Style="{StaticResource TitleTextStyle}"/><ItemsControl ItemsSource="{Binding DataContext.InventoryRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Border>
                        <Border Grid.Column="1" Style="{StaticResource SubtleCardStyle}"><StackPanel><TextBlock Text="Companions" Style="{StaticResource TitleTextStyle}"/><ItemsControl ItemsSource="{Binding DataContext.CompanionRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Border>
                        <Border Grid.Column="2" Style="{StaticResource SubtleCardStyle}"><StackPanel><TextBlock Text="Holdings" Style="{StaticResource TitleTextStyle}"/><ItemsControl ItemsSource="{Binding DataContext.HoldingsRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Border>
                        <Border Grid.Column="3" Style="{StaticResource SubtleCardStyle}"><StackPanel><TextBlock Text="Reputation" Style="{StaticResource TitleTextStyle}"/><ItemsControl ItemsSource="{Binding DataContext.ReputationRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <DataTemplate x:Key="RequestsTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}">
            <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Pending requests" Style="{StaticResource SectionTitleTextStyle}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Requests"/>
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Requests"/>
                    </StackPanel>
                </DockPanel>
                <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
                    <DataGrid ItemsSource="{Binding DataContext.PendingRequests, RelativeSource={RelativeSource AncestorType=Window}}" SelectedValuePath="Id" SelectedValue="{Binding DataContext.SelectedPendingRequestId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}">
                        <DataGrid.Columns><DataGridTextColumn Header="RequestId" Binding="{Binding Id}"/><DataGridTextColumn Header="Type" Binding="{Binding Name}"/><DataGridTextColumn Header="Status" Binding="{Binding State}"/><DataGridTextColumn Header="Details" Binding="{Binding Extra}"/></DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <Border Style="{StaticResource SubtleCardStyle}"><StackPanel><TextBlock Text="Комментарий админа" Style="{StaticResource TitleTextStyle}"/><TextBox Height="80" TextWrapping="Wrap" Text="{Binding DataContext.RequestComment, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><WrapPanel><Button Content="Approve" Command="{Binding DataContext.ApproveRequestCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanModerateSelectedRequest, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Reject" Command="{Binding DataContext.RejectRequestCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanModerateSelectedRequest, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel></StackPanel></Border>
                        <Border Style="{StaticResource SubtleCardStyle}"><StackPanel><TextBlock Text="История заявок" Style="{StaticResource TitleTextStyle}"/><ItemsControl ItemsSource="{Binding DataContext.RequestHistoryRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Border>
                        <Border Style="{StaticResource SubtleCardStyle}" Margin="0,10,0,0"><StackPanel><TextBlock Text="Контекст выбора" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding SelectedPlayerSummary}" Margin="0,6,0,0"/><TextBlock Text="{Binding SelectedCharacterSummary}" Margin="0,4,0,0"/><TextBlock Text="{Binding SelectedRequestSummary}" Margin="0,4,0,0"/><TextBlock Text="{Binding CharacterActionSummary}" Margin="0,4,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="DiceFeedTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}">
            <StackPanel Margin="8">
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Dice feed" Style="{StaticResource SectionTitleTextStyle}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="DiceFeed"/>
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="DiceFeed"/>
                    </StackPanel>
                </DockPanel>
                <ListBox ItemsSource="{Binding DataContext.DiceFeedRows, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="CombatTrackerTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}">
            <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Combat tracker" Style="{StaticResource SectionTitleTextStyle}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="CombatTracker"/>
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="CombatTracker"/>
                    </StackPanel>
                </DockPanel>
                <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
                    <StackPanel Margin="8">
                        <WrapPanel><TextBox Width="160" Text="{Binding DataContext.CombatSessionId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Start" Command="{Binding DataContext.CombatStartCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlCombat, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="End" Command="{Binding DataContext.CombatEndCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlCombat, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Refresh" Command="{Binding DataContext.CombatRefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.IsIdle, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel>
                        <WrapPanel><Button Style="{StaticResource GhostButtonStyle}" Content="NextTurn" Command="{Binding DataContext.CombatNextTurnCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlCombat, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="PrevTurn" Command="{Binding DataContext.CombatPrevTurnCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlCombat, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="NextRound" Command="{Binding DataContext.CombatNextRoundCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlCombat, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="SkipTurn" Command="{Binding DataContext.CombatSkipTurnCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlCombat, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel>
                        <WrapPanel><TextBox Width="160" Text="{Binding DataContext.NewParticipantName, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="100" Text="{Binding DataContext.NewParticipantKind, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Content="AddParticipant" Command="{Binding DataContext.CombatAddParticipantCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlCombat, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel>
                        <WrapPanel><TextBox Width="220" Text="{Binding DataContext.SelectedCombatParticipantId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Remove" Command="{Binding DataContext.CombatRemoveParticipantCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanManageCombatSelection, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="DetachCompanion" Command="{Binding DataContext.CombatDetachCompanionCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanManageCombatSelection, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel>
                        <TextBlock Text="{Binding DataContext.SelectedCombatParticipantSummary, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                        <ListBox ItemsSource="{Binding DataContext.CombatRows, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                    <Border Grid.Column="1" Style="{StaticResource SubtleCardStyle}"><StackPanel><TextBlock Text="История боя" Style="{StaticResource TitleTextStyle}"/><ListBox ItemsSource="{Binding DataContext.CombatHistoryRows, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel></Border>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="NotesManagementTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}">
            <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Notes management" Style="{StaticResource SectionTitleTextStyle}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="NotesManagement"/>
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="NotesManagement"/>
                    </StackPanel>
                </DockPanel>
                <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource SubtleCardStyle}"><StackPanel><TextBlock Text="{Binding DataContext.CharacterActionSummary, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,0,8" TextWrapping="Wrap"/><WrapPanel><TextBox Width="120" Text="{Binding DataContext.NoteSessionId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="120" Text="{Binding DataContext.NoteTargetType, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="180" Text="{Binding DataContext.NoteTargetId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Refresh" Command="{Binding DataContext.NotesRefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanRefreshNotes, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><TextBox Text="{Binding DataContext.NoteTitle, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Height="80" TextWrapping="Wrap" Text="{Binding DataContext.NoteText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><WrapPanel><TextBox Width="140" Text="{Binding DataContext.NoteVisibility, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Create" Command="{Binding DataContext.NotesCreateCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanCreateNote, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><WrapPanel><TextBox Width="220" Text="{Binding DataContext.SelectedNoteId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Archive" Command="{Binding DataContext.NotesArchiveCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanArchiveNote, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel></StackPanel></Border>
                    <ListBox Grid.Column="1" ItemsSource="{Binding DataContext.NotesRows, RelativeSource={RelativeSource AncestorType=Window}}" Margin="8"/>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SessionChatTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}">
            <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Session chat" Style="{StaticResource SectionTitleTextStyle}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="SessionChat"/>
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="SessionChat"/>
                    </StackPanel>
                </DockPanel>
                <ListBox Grid.Row="1" ItemsSource="{Binding DataContext.ChatRows, RelativeSource={RelativeSource AncestorType=Window}}"/>
                <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel><WrapPanel><TextBox Width="160" Text="{Binding DataContext.ChatSessionId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="120" Text="{Binding DataContext.ChatMessageType, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Refresh" Command="{Binding DataContext.ChatRefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.IsIdle, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><TextBox Text="{Binding DataContext.ChatMessageText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Отправить" Command="{Binding DataContext.ChatSendCommand, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Left" IsEnabled="{Binding DataContext.CanSendChat, RelativeSource={RelativeSource AncestorType=Window}}"/><TextBlock Text="{Binding DataContext.ChatUnreadText, RelativeSource={RelativeSource AncestorType=Window}}"/></StackPanel>
                    <Border Grid.Column="1" Style="{StaticResource SubtleCardStyle}"><StackPanel><TextBlock Text="Модерация" Style="{StaticResource TitleTextStyle}"/><TextBlock Text="{Binding DataContext.ChatModerationSummary, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,6,0,8" TextWrapping="Wrap"/><TextBox Text="{Binding DataContext.ChatModerationUserId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Text="{Binding DataContext.ChatModerationReason, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><WrapPanel><Button Style="{StaticResource GhostButtonStyle}" Content="Mute" Command="{Binding DataContext.ChatMuteUserCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanModerateChatUser, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Unmute" Command="{Binding DataContext.ChatUnmuteUserCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanModerateChatUser, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><WrapPanel><Button Style="{StaticResource GhostButtonStyle}" Content="Lock players" Command="{Binding DataContext.ChatLockPlayersCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanManageChatControls, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Unlock players" Command="{Binding DataContext.ChatUnlockPlayersCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanManageChatControls, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><WrapPanel><TextBox Width="60" Text="{Binding DataContext.ChatSlowPublicSeconds, RelativeSource={RelativeSource AncestorType=Window}}"/><TextBox Width="60" Text="{Binding DataContext.ChatSlowHiddenSeconds, RelativeSource={RelativeSource AncestorType=Window}}"/><TextBox Width="60" Text="{Binding DataContext.ChatSlowAdminOnlySeconds, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Slow mode" Command="{Binding DataContext.ChatSetSlowModeCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanManageChatControls, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><ListBox ItemsSource="{Binding DataContext.ChatRestrictionRows, RelativeSource={RelativeSource AncestorType=Window}}" Height="140"/></StackPanel></Border>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SessionAudioTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}">
            <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Session audio" Style="{StaticResource SectionTitleTextStyle}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Вернуть в окно" Command="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="SessionAudio"/>
                        <Button Style="{StaticResource GhostButtonStyle}" Content="Скрыть" Command="{Binding DataContext.ToggleWorkspacePanelVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="SessionAudio"/>
                    </StackPanel>
                </DockPanel>
                <Border Grid.Row="1" Style="{StaticResource SubtleCardStyle}"><StackPanel><TextBlock Text="{Binding DataContext.AudioStateText, RelativeSource={RelativeSource AncestorType=Window}}"/><WrapPanel><TextBox Width="140" Text="{Binding DataContext.AudioSessionId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="120" Text="{Binding DataContext.AudioModeInput, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="120" Text="{Binding DataContext.AudioCategoryInput, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Refresh" Command="{Binding DataContext.AudioRefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.IsIdle, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Content="Set mode" Command="{Binding DataContext.AudioSetModeCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Next" Command="{Binding DataContext.AudioNextTrackCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Clear override" Command="{Binding DataContext.AudioClearOverrideCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel><WrapPanel><TextBox Width="220" Text="{Binding DataContext.AudioSelectedTrackId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/><Button Content="Select track" Command="{Binding DataContext.AudioSelectTrackCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/><Button Style="{StaticResource GhostButtonStyle}" Content="Reload library" Command="{Binding DataContext.AudioReloadLibraryCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/></WrapPanel></StackPanel></Border>
                <ListBox Grid.Row="2" ItemsSource="{Binding DataContext.AudioLibraryRows, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="NRI / Admin" Style="{StaticResource HeaderTitleTextStyle}" Margin="0,0,12,0"/>
                    <Border Style="{StaticResource StatusBadgeStyle}" Margin="0,0,10,0"><TextBlock Text="{Binding ConnectionState}" Style="{StaticResource TitleTextStyle}"/></Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding HeaderStatusSummary}" Style="{StaticResource TitleTextStyle}"/>
                        <StackPanel><TextBlock Text="{Binding SessionSummary}" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" MaxWidth="700"/><TextBlock Text="{Binding BusyMessage}" Foreground="{StaticResource AccentBrush}"><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsBusy}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></StackPanel>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
