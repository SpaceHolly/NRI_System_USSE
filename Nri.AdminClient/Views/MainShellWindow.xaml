                            <Button Content="Применить режим" Command="{Binding DataContext.AudioSetModeCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Button Style="{StaticResource GhostButtonStyle}" Content="Следующий" Command="{Binding DataContext.AudioNextTrackCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Button Style="{StaticResource GhostButtonStyle}" Content="Сбросить override" Command="{Binding DataContext.AudioClearOverrideCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </WrapPanel>
                        <WrapPanel>
                            <TextBox Width="220" Text="{Binding DataContext.AudioSelectedTrackId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Выбрать трек" Command="{Binding DataContext.AudioSelectTrackCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Button Style="{StaticResource GhostButtonStyle}" Content="Обновить библиотеку" Command="{Binding DataContext.AudioReloadLibraryCommand, RelativeSource={RelativeSource AncestorType=Window}}" IsEnabled="{Binding DataContext.CanControlAudio, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <ListBox Grid.Row="2" ItemsSource="{Binding DataContext.AudioLibraryRows, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource StatusBadgeStyle}" VerticalAlignment="Center" Height="30" Padding="12,4">
                    <TextBlock Text="{Binding ConnectionState}" Foreground="#FFF8FAFC" FontWeight="SemiBold"/>
                </Border>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="NRI • Панель администратора" Style="{StaticResource HeaderTitleTextStyle}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding HeaderStatusSummary}" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding SessionSummary}" HorizontalAlignment="Center" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" MaxWidth="760"/>
                    <TextBlock Text="{Binding BusyMessage}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Обновить всё" Command="{Binding RefreshCommand}" IsEnabled="{Binding IsIdle}"/>
                    <Button x:Name="ServerButton" Style="{StaticResource GhostButtonStyle}" Content="Сервер" Command="{Binding OpenConnectionPopupCommand}"/>
                    <Button x:Name="AuthButton" Style="{StaticResource GhostButtonStyle}" Content="Авторизация" Command="{Binding ToggleAuthPopupCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="212"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,8,8,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Разделы" Style="{StaticResource SectionTitleTextStyle}" Margin="0,0,0,8"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Обзор" Command="{Binding SelectSectionCommand}" CommandParameter="Обзор"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Люди" Command="{Binding SelectSectionCommand}" CommandParameter="Люди"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Персонажи" Command="{Binding SelectSectionCommand}" CommandParameter="Персонажи"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Модерация" Command="{Binding SelectSectionCommand}" CommandParameter="Модерация"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Сессия" Command="{Binding SelectSectionCommand}" CommandParameter="Сессия"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Контент" Command="{Binding SelectSectionCommand}" CommandParameter="Контент"/>
                        <Button Style="{StaticResource SectionNavButtonStyle}" Content="Система" Command="{Binding SelectSectionCommand}" CommandParameter="Система"/>
                        <Border Style="{StaticResource SubtleCardStyle}" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Рабочие панели" Style="{StaticResource TitleTextStyle}"/>
                                <TextBlock Text="{Binding WorkspaceSummary}" Margin="0,4,0,8"/>
                                <ItemsControl ItemsSource="{Binding WorkspacePanels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SubtleCardStyle}" Padding="6" Margin="0,0,0,5">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" Style="{StaticResource TitleTextStyle}"/>
                                                            <TextBlock Text="{Binding PanelState}"/>
                                                        </StackPanel>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding StateBadge}" FontSize="18" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <WrapPanel Margin="0,4,0,0">
                                                        <Button Style="{StaticResource GhostButtonStyle}" CommandParameter="{Binding PanelId}" IsEnabled="{Binding DataContext.CanManageWorkspace, RelativeSource={RelativeSource AncestorType=Window}}">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                                    <Setter Property="Content" Value="Открыть отдельно"/>
                                                                    <Setter Property="Command" Value="{Binding DataContext.DetachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDetached}" Value="True">
                                                                            <Setter Property="Content" Value="Вернуть в окно"/>
                                                                            <Setter Property="Command" Value="{Binding DataContext.AttachWorkspacePanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SubtleCardStyle}" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Контекст выбора" Style="{StaticResource TitleTextStyle}"/>
                                <TextBlock Text="{Binding SelectedPlayerSummary}" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding SelectedCharacterSummary}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedRequestSummary}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding CharacterActionSummary}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" Margin="0,8,0,0">
                <TabControl Style="{StaticResource SectionHostTabControlStyle}" SelectedValue="{Binding SelectedSection}" SelectedValuePath="Tag">
                    <TabItem Header="Обзор" Tag="Обзор">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource SummaryMetricCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Соединение" Style="{StaticResource TitleTextStyle}"/>
