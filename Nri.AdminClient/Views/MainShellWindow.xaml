                                                    <Button Style="{StaticResource GhostButtonStyle}" Content="К персонажам" Command="{Binding SelectSectionCommand}" CommandParameter="Персонажи" IsEnabled="{Binding CanLoadPlayerCharacters}"/>
                                                </WrapPanel>
                                                <TextBlock Text="{Binding SelectedOwnerUserId, StringFormat=ID игрока: {0}}" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Персонажи">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SubtleCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Персонажи по игроку" Style="{StaticResource TitleTextStyle}"/>
                                                <WrapPanel>
                                                    <TextBox Width="250" Text="{Binding SelectedOwnerUserId, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <Button Content="Загрузить" Command="{Binding LoadOwnerCharactersCommand}"/>
                                                </WrapPanel>
                                                <TextBox Margin="0,8,0,6" Text="{Binding CharactersSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Поиск по имени, id или дополнительному полю"/>
                                                <ListBox ItemsSource="{Binding FilteredCharacters}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding SelectedCharacterId, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SubtleCardStyle}">
