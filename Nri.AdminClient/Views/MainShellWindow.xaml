                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" Margin="0,8,0,0">
                <TabControl Style="{StaticResource SectionHostTabControlStyle}" SelectedValue="{Binding SelectedSection}" SelectedValuePath="Tag">
                    <TabItem Header="Обзор" Tag="Обзор">
