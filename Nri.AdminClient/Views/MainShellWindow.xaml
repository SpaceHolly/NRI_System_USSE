                                            <TextBlock Text="{Binding LocksCount, StringFormat=Блокировок: {0}}"/>
                                            <TextBlock Text="{Binding HasActiveCombat, StringFormat=Бой активен: {0}}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" Style="{StaticResource SummaryMetricCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Сессия" Style="{StaticResource TitleTextStyle}"/>
