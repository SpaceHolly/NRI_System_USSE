                            </WrapPanel>
                            <ListBox ItemsSource="{Binding DataContext.ChatRestrictionRows, RelativeSource={RelativeSource AncestorType=Window}}" Height="140"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SessionAudioTemplate" DataType="{x:Type vm:WorkspacePanelDescriptor}">
