                            <TextBox Width="140" Text="{Binding DataContext.AudioSessionId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Width="120" Text="{Binding DataContext.AudioModeInput, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Width="120" Text="{Binding DataContext.AudioCategoryInput, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
