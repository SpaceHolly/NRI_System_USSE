                    <TabItem Header="Модерация" Tag="Модерация"><TabControl Margin="8"><TabItem Header="Requests"><ContentControl Content="{Binding RequestsPanel}" ContentTemplate="{StaticResource RequestsTemplate}"><ContentControl.Style><Style TargetType="ContentControl"><Style.Triggers><DataTrigger Binding="{Binding RequestsPanel.IsVisible}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger><DataTrigger Binding="{Binding RequestsPanel.IsDetached}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></ContentControl.Style></ContentControl></TabItem><TabItem Header="Dice"><ContentControl Content="{Binding DiceFeedPanel}" ContentTemplate="{StaticResource DiceFeedTemplate}"><ContentControl.Style><Style TargetType="ContentControl"><Style.Triggers><DataTrigger Binding="{Binding DiceFeedPanel.IsVisible}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger><DataTrigger Binding="{Binding DiceFeedPanel.IsDetached}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></ContentControl.Style></ContentControl></TabItem><TabItem Header="Notes"><ContentControl Content="{Binding NotesPanel}" ContentTemplate="{StaticResource NotesManagementTemplate}"><ContentControl.Style><Style TargetType="ContentControl"><Style.Triggers><DataTrigger Binding="{Binding NotesPanel.IsVisible}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger><DataTrigger Binding="{Binding NotesPanel.IsDetached}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></ContentControl.Style></ContentControl></TabItem></TabControl></TabItem>
                    <TabItem Header="Сессия" Tag="Сессия"><TabControl Margin="8"><TabItem Header="Combat"><ContentControl Content="{Binding CombatTrackerPanel}" ContentTemplate="{StaticResource CombatTrackerTemplate}"><ContentControl.Style><Style TargetType="ContentControl"><Style.Triggers><DataTrigger Binding="{Binding CombatTrackerPanel.IsVisible}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger><DataTrigger Binding="{Binding CombatTrackerPanel.IsDetached}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></ContentControl.Style></ContentControl></TabItem><TabItem Header="Chat"><ContentControl Content="{Binding SessionChatPanel}" ContentTemplate="{StaticResource SessionChatTemplate}"><ContentControl.Style><Style TargetType="ContentControl"><Style.Triggers><DataTrigger Binding="{Binding SessionChatPanel.IsVisible}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger><DataTrigger Binding="{Binding SessionChatPanel.IsDetached}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></ContentControl.Style></ContentControl></TabItem><TabItem Header="Audio"><ContentControl Content="{Binding SessionAudioPanel}" ContentTemplate="{StaticResource SessionAudioTemplate}"><ContentControl.Style><Style TargetType="ContentControl"><Style.Triggers><DataTrigger Binding="{Binding SessionAudioPanel.IsVisible}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger><DataTrigger Binding="{Binding SessionAudioPanel.IsDetached}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></ContentControl.Style></ContentControl></TabItem></TabControl></TabItem>
                    <TabItem Header="Контент" Tag="Контент"><TabControl Margin="8"><TabItem Header="Reference data"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions><StackPanel Margin="8"><WrapPanel Margin="0,0,0,6"><TextBox Width="120" Text="{Binding ReferenceWorldId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/><TextBox Width="120" Text="{Binding ReferenceType, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/><Button Content="Refresh" Command="{Binding ReferenceRefreshCommand}"/></WrapPanel><TextBox Text="{Binding ReferenceId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/><TextBox Text="{Binding ReferenceKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/><TextBox Text="{Binding ReferenceDisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/><TextBox Text="{Binding ReferenceDataJson, UpdateSourceTrigger=PropertyChanged}" Height="80" TextWrapping="Wrap" Margin="0,0,0,6"/><WrapPanel><Button Content="Create" Command="{Binding ReferenceCreateCommand}" Margin="0,0,6,0"/><Button Content="Update" Command="{Binding ReferenceUpdateCommand}" Margin="0,0,6,0"/><Button Content="Archive" Command="{Binding ReferenceArchiveCommand}"/></WrapPanel></StackPanel><ListBox Grid.Column="1" ItemsSource="{Binding ReferenceRows}" Margin="8"/></Grid></TabItem></TabControl></TabItem>
                    <TabItem Header="Система" Tag="Система"><TabControl Margin="8"><TabItem Header="Backups"><StackPanel Margin="8"><WrapPanel Margin="0,0,0,6"><Button Content="Refresh" Command="{Binding BackupRefreshCommand}" Margin="0,0,6,0"/><TextBox Width="220" Text="{Binding BackupLabel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/><Button Content="Create backup" Command="{Binding BackupCreateCommand}"/></WrapPanel><WrapPanel Margin="0,0,0,6"><TextBox Width="220" Text="{Binding SelectedBackupId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/><Button Content="Restore" Command="{Binding BackupRestoreCommand}" Margin="0,0,6,0"/><Button Content="Export" Command="{Binding BackupExportCommand}"/></WrapPanel><ListBox ItemsSource="{Binding BackupRows}" Height="220"/></StackPanel></TabItem><TabItem Header="Diagnostics"><StackPanel Margin="8"><Button Content="Refresh diagnostics" Command="{Binding DiagnosticsRefreshCommand}" Margin="0,0,0,8"/><ListBox ItemsSource="{Binding DiagnosticsRows}" Height="260"/></StackPanel></TabItem></TabControl></TabItem>
